---
import { getCollection } from 'astro:content';
import { getImage } from 'astro:assets';
import { resolveImage } from '../../utils/imageImports';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import TestimonialCard from '../../components/TestimonialCard.astro';
import CategorySidebar from '../../components/CategorySidebar.astro';
import Pagination from '../../components/Pagination.astro';
import CTABlock from '../../components/CTABlock.astro';
import { VOICE_FILTER_CATEGORIES, getTestimonialImageSrc } from '../../data/caseVoiceData';
import { generateAggregateRating, serializeJsonLd } from '../../utils/schema';
import { SITE_CONFIG } from '../../utils/siteConfig';

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const allTestimonials = await getCollection('testimonials');
  return paginate(allTestimonials, { pageSize: 10 });
}

const { page } = Astro.props;

const optimizedImages: Record<string, string> = {};
for (const item of page.data) {
  const src = getTestimonialImageSrc(item.id, item.data.serviceCategory);
  const meta = await resolveImage(src);
  if (meta) {
    const opt = await getImage({ src: meta, width: 300, height: 300, format: 'webp', quality: 80 });
    optimizedImages[item.id] = opt.src;
  }
}

const aggregateReviewSchema = generateAggregateRating(
  page.data.map((item: any) => ({
    serviceType: item.data.serviceType,
    cost: item.data.cost,
    message: item.data.message,
    author: item.data.authorInitial ?? '匿名',
    itemReviewed: item.data.serviceType,
    ratingValue: item.data.rating,
  }))
);

const breadcrumbItems = [
  { label: 'TOP', href: '/' },
  { label: 'お客様の声', href: '/voice/' },
];
---

<BaseLayout title={`お客様の声${page.currentPage > 1 ? `（${page.currentPage}ページ目）` : ''} | 設備プロ`} description="設備プロをご利用いただいたお客様の声をご紹介します。水まわりや電気のトラブル対応に関するリアルな評価をご覧ください。" canonicalUrl={`${SITE_CONFIG.siteUrl}/voice/${page.currentPage === 1 ? '' : page.currentPage + '/'}`}>
  {aggregateReviewSchema && (
    <script type="application/ld+json" set:html={serializeJsonLd(aggregateReviewSchema)} />
  )}

  <section class="py-[30px] sm:py-[40px] md:py-[60px]">
    <div class="max-w-[1200px] mx-auto px-3 sm:px-4">
      <Breadcrumb items={breadcrumbItems} />

      <h1 class="text-[18px] sm:text-[24px] md:text-[42px] font-bold relative isolate flex flex-col items-center text-center mt-[20px] sm:mt-[30px] md:mt-[40px]">
        <span class="block w-[2px] h-[25px] sm:h-[40px] md:h-[70px] bg-navy"></span>
        <span>お客様の声</span>
      </h1>
    </div>
  </section>

  <section class="archive-lead">
    <div class="max-w-[1200px] mx-auto px-3 sm:px-4">
      <p class="text-[12px] sm:text-[14px] md:text-[16px] leading-[1.8] text-center font-bold text-shadow-[2px_1px_0_#fff]">
        設備プロは、水まわりや電気のトラブルに迅速に対応し、<br class="hidden sm:inline">
        お客様の快適な暮らしをサポートしております。<br>
        お客様からの率直なご意見は、私たちにとって大きな励みであり、<br class="hidden sm:inline">
        より良いサービスを提供への糧とさせていただいております。
      </p>
    </div>
  </section>

  <h2 class="under-heading">お客様の声一覧</h2>

  <section class="py-[20px] sm:py-[30px] md:py-[40px]">
    <div class="archive-inner max-w-[1150px] mx-auto px-3 sm:px-4">
      <div class="archive-main">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-[20px] sm:gap-[24px] md:gap-[33px_38px]">
          {page.data.map((item: any) => (
            <TestimonialCard
              serviceType={item.data.serviceType}
              serviceCategory={item.data.serviceCategory}
              title={item.data.title}
              duration={item.data.duration}
              cost={item.data.cost}
              message={item.data.message}
              authorInitial={item.data.authorInitial}
              location={item.data.location}
              imageSrc={optimizedImages[item.id] ?? getTestimonialImageSrc(item.id, item.data.serviceCategory)}
              imageAlt={`${item.data.serviceType}のお客様の声`}
            />
          ))}
        </div>

        <Pagination
          currentPage={page.currentPage}
          totalPages={page.lastPage}
          baseUrl="/voice"
        />
      </div>

      <CategorySidebar
        categories={VOICE_FILTER_CATEGORIES as any}
        filterBasePath="/voice/category/"
      />
    </div>
  </section>
  <CTABlock />
</BaseLayout>

<style>
  .archive-lead {
    padding: 40px 0;
    border-radius: 40px;
    background: #f7f7f7;
    margin: 0 auto;
    max-width: 1200px;
  }
  .under-heading {
    font-size: 22px;
    font-weight: 800;
    text-align: center;
    padding-bottom: 15px;
    position: relative;
    margin-top: 40px;
  }
  .under-heading::after {
    content: "";
    display: block;
    background-color: #1B2A4A;
    width: 40px;
    height: 2px;
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
  }
  .archive-inner {
    display: flex;
    gap: 52px;
  }
  .archive-main {
    flex-grow: 1;
    min-width: 0;
  }
  @media (min-width: 901px) {
    .under-heading {
      font-size: 32px;
    }
    .archive-lead {
      padding: 66px;
    }
  }
  @media (max-width: 900px) {
    .archive-inner {
      flex-direction: column;
      gap: 0;
    }
    .archive-lead {
      padding: 30px 16px;
      border-radius: 20px;
    }
  }
</style>
