---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import AnchorMenu from '../../components/AnchorMenu.astro';
import PricingTier from '../../components/PricingTier.astro';
import ReasonsGrid from '../../components/ReasonsGrid.astro';
import ProcessFlow from '../../components/ProcessFlow.astro';
import AreaMap from '../../components/AreaMap.astro';
import CaseStudyCard from '../../components/CaseStudyCard.astro';
import TestimonialCard from '../../components/TestimonialCard.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import CTABlock from '../../components/CTABlock.astro';
import { SITE_CONFIG } from '../../utils/siteConfig';

export function getStaticPaths() {
  return [
    { params: { service: 'breaker' } },
  ];
}

const { service } = Astro.params;

const serviceName = 'ブレーカー';
const serviceLongName = 'ブレーカー修理・交換';
const serviceCategory = '電気まわり';
const categorySlug = 'electricity';

const originalPrice = 2600;
const discountedPrice = 1100;
const webDiscountAmount = 1500;

const breadcrumbItems = [
  { label: 'TOP', href: '/' },
  { label: serviceCategory, href: `/${categorySlug}` },
  { label: `${serviceName}サービス`, href: '#' },
];

const anchorSections = [
  { id: 'price', label: '料金のご案内', icon: '/images/icons/anchor_icon_01.svg' },
  { id: 'reason', label: '選ばれる理由', icon: '/images/icons/anchor_icon_02.svg' },
  { id: 'compare', label: '他社比較', icon: '/images/icons/anchor_icon_03.svg' },
  { id: 'area', label: '対応エリア', icon: '/images/icons/anchor_icon_04.svg' },
  { id: 'flow', label: '作業の流れ', icon: '/images/icons/anchor_icon_05.svg' },
  { id: 'case', label: '修理事例', icon: '/images/icons/anchor_icon_06.svg' },
  { id: 'faq', label: 'FAQ', icon: '/images/icons/anchor_icon_07.svg' },
];

const pricingTiers = [
  {
    name: '漏電調査・応急処置',
    price: 17600,
    imageUrl: '/images/services/electricity_01.jpg',
    imageAlt: '漏電調査・応急処置サービス',
  },
  {
    name: 'ブレーカー新設（配線作業込み）',
    price: 20000,
    imageUrl: '/images/services/electricity_02.jpg',
    imageAlt: 'ブレーカー新設サービス',
  },
  {
    name: 'ブレーカー交換',
    price: 14000,
    imageUrl: '/images/services/electricity_03.jpg',
    imageAlt: 'ブレーカー交換サービス',
  },
];

const faqItems = [
  {
    question: 'ブレーカーが頻繁に落ちるのですが、原因は何ですか？',
    answer: '主な原因は、電気の使いすぎによる過電流、漏電、ブレーカー本体の劣化の3つです。頻繁に落ちる場合は専門スタッフによる調査をおすすめします。',
  },
  {
    question: '修理にどのくらい時間がかかりますか？',
    answer: '通常30分～1時間程度です。ブレーカー交換の場合は1～2時間ほどかかる場合があります。',
  },
  {
    question: '見積りは無料ですか？',
    answer: 'はい、お見積りは完全無料です。出張費やキャンセル料もいただきません。ご納得いただけない場合はお断りいただいて構いません。',
  },
  {
    question: '深夜や早朝でも対応してもらえますか？',
    answer: 'はい、24時間365日対応しております。深夜・早朝でも追加料金はいただきません。',
  },
];

const stubCaseStudies = [
  {
    title: 'マンションのブレーカー交換工事',
    serviceCategory: 'electricity' as const,
    categoryLabel: '電気まわり',
    location: '東京都',
    duration: '60',
    cost: 20000,
    description: 'マンションのブレーカーが頻繁に落ちるとのご相談。調査の結果、ブレーカー本体の劣化が原因と判明し、交換工事を実施しました。',
    imageSrc: '/images/cases/case_01.jpg',
    imageAlt: 'ブレーカー交換工事の施工事例',
    slug: 'case-001',
  },
  {
    title: '漏電調査と応急処置',
    serviceCategory: 'electricity' as const,
    categoryLabel: '電気まわり',
    location: '大阪府',
    duration: '45',
    cost: 17600,
    description: '漏電ブレーカーが頻繁にトリップするとのご相談。漏電箇所を特定し、応急処置を行いました。',
    imageSrc: '/images/cases/case_02.jpg',
    imageAlt: '漏電調査の施工事例',
    slug: 'case-002',
  },
];

const stubTestimonials = [
  {
    serviceType: 'ブレーカー修理',
    serviceCategory: 'electricity' as const,
    cost: 14000,
    message: '深夜にブレーカーが落ちてしまい、すぐに駆けつけてくれました。丁寧に原因を説明していただき、安心して任せることができました。',
    authorInitial: 'T.K',
    location: '東京都',
    imageSrc: '/images/cases/case_03.jpg',
    imageAlt: 'ブレーカー修理のお客様の声',
  },
  {
    serviceType: 'ブレーカー交換',
    serviceCategory: 'electricity' as const,
    cost: 20000,
    message: '見積り通りの金額で、追加料金もなく安心でした。作業も丁寧で、交換後は一度もブレーカーが落ちていません。',
    authorInitial: 'S.M',
    location: '大阪府',
    imageSrc: '/images/cases/case_04.jpg',
    imageAlt: 'ブレーカー交換のお客様の声',
  },
];

const pageTitle = `${serviceLongName}なら${SITE_CONFIG.companyName}【年中無休・即対応】`;
const pageDescription = `${serviceLongName}なら${SITE_CONFIG.companyName}にお任せください。24時間365日対応、お見積り無料。`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <!-- Section 1: Breadcrumb -->
  <div class="max-w-[1200px] mx-auto px-3 sm:px-4 py-3 sm:py-4">
    <Breadcrumb items={breadcrumbItems} />
  </div>

  <!-- Section 2: KV (Key Visual) -->
  <div class="w-full">
    <picture>
      <source media="(max-width: 900px)" srcset="/images/services/electricity/breaker/kv_sp.png" />
      <source media="(min-width: 901px)" srcset="/images/services/electricity/breaker/kv.png" />
      <img
        src="/images/services/electricity/breaker/kv.png"
        alt={`${serviceLongName}サービス`}
        width="1200"
        height="500"
        class="w-full h-auto object-cover"
        loading="eager"
        decoding="async"
      />
    </picture>
  </div>

  <!-- KV Bottom: Price bar -->
  <div class="bg-[#0044f2]">
    <div class="max-w-[1200px] mx-auto px-3 sm:px-4 h-[60px] sm:h-[80px] md:h-[100px] flex items-center justify-center">
      <div class="flex items-center gap-2 sm:gap-4 md:gap-6">
        <div class="bg-white rounded-[16px] sm:rounded-[20px] md:rounded-[22px] px-3 sm:px-6 md:px-8 py-1.5 sm:py-2 flex items-center gap-2 sm:gap-3">
          <span class="bg-black text-white text-[9px] sm:text-[11px] md:text-[14px] font-bold leading-tight px-2 sm:px-3 py-1 sm:py-1.5 rounded-[5px] flex items-center justify-center">WEB割引</span>
          <span class="font-[Roboto] text-[16px] sm:text-[22px] md:text-[29px] font-bold flex items-center">
            {webDiscountAmount.toLocaleString('ja-JP')}<span class="font-['Noto_Sans_JP'] text-[11px] sm:text-[14px] md:text-[19px] font-extrabold ml-0.5">円割引！</span>
          </span>
        </div>
        <div class="text-white text-center">
          <span class="block text-[10px] sm:text-[12px] md:text-[15px] font-extrabold">作業料金</span>
          <span class="text-[14px] sm:text-[18px] md:text-[23px] font-bold">{originalPrice.toLocaleString('ja-JP')}円</span>
        </div>
        <div class="w-[10px] sm:w-[14px] md:w-[17px] h-auto aspect-[17/41] bg-[#fbc102] flex-shrink-0" style="clip-path: polygon(100% 50%, 0% 0%, 0% 100%);"></div>
        <p class="font-[Roboto] text-[28px] sm:text-[46px] md:text-[68px] font-black text-[#fbfb00] leading-none">
          {discountedPrice.toLocaleString('ja-JP')}<span class="font-['Noto_Sans_JP'] text-[12px] sm:text-[16px] md:text-[21px] font-semibold text-white">円[税込]〜</span>
        </p>
      </div>
    </div>
  </div>

  <!-- Intro Section -->
  <section class="py-10 sm:py-14 md:py-20">
    <div class="max-w-[920px] mx-auto px-3 sm:px-4">
      <h1 class="text-[20px] sm:text-[26px] md:text-[32px] font-extrabold text-center pb-4 relative">
        {serviceName}のトラブルなら<wbr />設備人におまかせ
        <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[30px] sm:w-[35px] md:w-[40px] h-[2px] bg-[#fbc102]"></span>
      </h1>
      <p class="text-[13px] sm:text-[14px] md:text-[16px] leading-[1.75] mt-6 sm:mt-8 md:mt-10 text-text-primary" style="word-break: keep-all; overflow-wrap: anywhere;">
        ブレーカーが頻繁に落ちる・上がらない、分電盤から異音や焦げ臭いニオイがする、特定回路だけ通電しない、漏電ブレーカーが作動する――こうした電気まわりのトラブルは、ご家庭の中でも最優先で対処したい不具合の一つです。<br /><br />
        ブレーカーや配線の不具合を放置すると、家電の故障だけでなく感電・発煙・火災など重大事故につながるおそれがあります。症状が軽いうちに、できる限り早く専門業者へご相談いただくことをおすすめします。<br /><br />
        24時間年中無休の設備人なら、早朝・深夜を問わず熟練の作業スタッフが最速で駆けつけ、現場で安全確認と復旧作業を行います。お見積もり・キャンセル料は一切いただいておりません。突然のブレーカートラブルでも、まずはお気軽にご相談ください。
      </p>
    </div>
  </section>

  <!-- Consultation Section -->
  <section class="pb-4 sm:pb-6 md:pb-8">
    <div class="max-w-[1200px] mx-auto px-3 sm:px-4">
      <div class="bg-[#fbc101] rounded-[24px] sm:rounded-[32px] md:rounded-[40px] p-5 sm:p-8 md:p-12">
        <h2 class="text-[18px] sm:text-[24px] md:text-[32px] font-extrabold text-center underline decoration-[#feff00] decoration-4 underline-offset-[13px]">
          <span class="text-[#ff4176]">ご相談無料！</span>必ず事前にお見積り
        </h2>
        <p class="text-[11px] sm:text-[12px] md:text-[14px] leading-relaxed mt-4 sm:mt-6 md:mt-8 text-center max-w-[800px] mx-auto">
          作業費+材料費部品代+処分費(※)で作業料金を算出いたします。<br />
          それ以外にかかる見積り費や出張費、早朝・深夜料金、キャンセル料は一切いただきません。<br />
          作業前に必ずお見積りを提示しますので、まずは相談・見積もりご安心ください。
        </p>
        <figure class="mt-4 sm:mt-6 md:mt-8 max-w-[600px] mx-auto">
          <picture>
            <source media="(max-width: 900px)" srcset="/images/cta/cta_feature_sp.svg" />
            <source media="(min-width: 901px)" srcset="/images/cta/cta_feature.svg" />
            <img src="/images/cta/cta_feature.svg" alt="見積り無料・出張費無料・キャンセル料無料" loading="lazy" decoding="async" class="w-full h-auto" />
          </picture>
        </figure>
      </div>
    </div>
  </section>

  <!-- Anchor Menu -->
  <AnchorMenu sections={anchorSections} />

  <!-- Pricing Section -->
  <PricingTier tiers={pricingTiers} serviceName={`${serviceName}トラブル`} />

  <CTABlock variant="full-width" />

  <!-- Reasons Section -->
  <div id="reason">
    <ReasonsGrid />
  </div>

  <!-- Staff Qualifications -->
  <section class="py-12 md:py-16 lg:py-20">
    <div class="max-w-[1200px] mx-auto px-3 sm:px-4">
      <div class="flex justify-center">
        <div class="w-full max-w-[585px] rounded-[24px] sm:rounded-[32px] md:rounded-[40px] bg-cover bg-center bg-no-repeat flex flex-col items-center justify-center py-10 sm:py-12 md:py-[51px] px-4" style="background-image: url('/images/staff_bg.jpg');">
          <p class="text-[16px] sm:text-[18px] md:text-[22px] font-bold text-white text-center">電気関連有資格</p>
          <div class="flex flex-col gap-2 mt-5 sm:mt-6 md:mt-7 w-fit mx-auto">
            <div class="flex items-center">
              <p class="w-[180px] sm:w-[190px] md:w-[204px] h-[24px] sm:h-[25px] md:h-[27px] bg-white rounded-[13px] text-[11px] sm:text-[11px] md:text-[12px] font-bold text-[#333] flex items-center justify-center">第1種電気工事士</p>
            </div>
            <div class="flex items-center">
              <p class="w-[180px] sm:w-[190px] md:w-[204px] h-[24px] sm:h-[25px] md:h-[27px] bg-white rounded-[13px] text-[11px] sm:text-[11px] md:text-[12px] font-bold text-[#333] flex items-center justify-center">第2種電気工事士</p>
            </div>
            <div class="flex items-center">
              <p class="w-[180px] sm:w-[190px] md:w-[204px] h-[24px] sm:h-[25px] md:h-[27px] bg-white rounded-[13px] text-[11px] sm:text-[11px] md:text-[12px] font-bold text-[#333] flex items-center justify-center">低圧電気取扱業務特別教育</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section id="compare" class="py-12 md:py-16 lg:py-20">
    <div class="max-w-[1200px] mx-auto px-3 sm:px-4">
      <div class="border-[6px] border-[#e5e5e5] rounded-[24px] sm:rounded-[32px] md:rounded-[40px] px-3 sm:px-6 md:px-10 pb-6 sm:pb-8 md:pb-10">
        <h2 class="text-[18px] sm:text-[22px] md:text-[42px] font-bold relative flex flex-col items-center text-center pt-8 sm:pt-10 md:pt-12 mb-6 sm:mb-8 md:mb-12">
          <span class="block w-[2px] h-[25px] sm:h-[40px] md:h-[70px] bg-[#fbc102]"></span>
          <span class="absolute top-[50px] sm:top-[65px] md:top-[55px] left-1/2 -translate-x-1/2 opacity-30 font-[Roboto] text-[40px] sm:text-[70px] md:text-[180px] font-bold text-[#b3b3b3] whitespace-nowrap -z-[1] pointer-events-none">Compare</span>
          他社サービスと比較しました
        </h2>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse text-center" style="table-layout: fixed; min-width: 500px;">
            <colgroup>
              <col />
              <col class="border-4 border-[#fbc102]" />
              <col />
              <col />
            </colgroup>
            <tbody>
              <tr>
                <th class="bg-[#1c1c1c] text-white text-[11px] sm:text-[14px] md:text-[18px] font-bold p-2 sm:p-3 md:p-4 rounded-tl-lg"></th>
                <th class="bg-[#1c1c1c] text-white p-2 sm:p-3 md:p-4">
                  <img src="/images/site_logo.svg" alt="設備人" class="w-[60px] sm:w-[80px] md:w-[100px] mx-auto" />
                </th>
                <th class="bg-[#1c1c1c] text-white text-[11px] sm:text-[14px] md:text-[18px] font-bold p-2 sm:p-3 md:p-4">A社</th>
                <th class="bg-[#1c1c1c] text-white text-[11px] sm:text-[14px] md:text-[18px] font-bold p-2 sm:p-3 md:p-4 rounded-tr-lg">B社</th>
              </tr>
              <tr>
                <th class="bg-white text-[11px] sm:text-[14px] md:text-[18px] font-bold p-2 sm:p-3 md:p-4 sticky left-0 z-[3]">作業料金</th>
                <td class="bg-[#ffffdb] p-2 sm:p-3 md:p-4">
                  <span class="font-[Roboto] text-[20px] sm:text-[28px] md:text-[40px] font-black text-[#ff4176]">4,000<span class="text-[10px] sm:text-[12px] md:text-[14px] font-semibold">円[税込]〜</span></span>
                </td>
                <td class="p-2 sm:p-3 md:p-4"><span class="font-[Roboto] text-[16px] sm:text-[22px] md:text-[32px] font-medium text-[#3e3e3e]">4,000<span class="text-[10px] sm:text-[12px] md:text-[14px] font-semibold">円[税込]〜</span></span></td>
                <td class="p-2 sm:p-3 md:p-4"><span class="font-[Roboto] text-[16px] sm:text-[22px] md:text-[32px] font-medium text-[#3e3e3e]">4,000<span class="text-[10px] sm:text-[12px] md:text-[14px] font-semibold">円[税込]〜</span></span></td>
              </tr>
              <tr class="bg-[#f0f0f0]">
                <th class="bg-[#f0f0f0] text-[11px] sm:text-[14px] md:text-[18px] font-bold p-2 sm:p-3 md:p-4 sticky left-0 z-[3]">基本料金</th>
                <td class="bg-[#f5f5c4] p-2 sm:p-3 md:p-4"><span class="font-[Roboto] text-[20px] sm:text-[28px] md:text-[40px] font-black text-[#ff4176]">0<span class="text-[10px] sm:text-[12px] md:text-[14px] font-semibold">円</span></span></td>
                <td class="p-2 sm:p-3 md:p-4"><span class="font-[Roboto] text-[16px] sm:text-[22px] md:text-[32px] font-medium text-[#3e3e3e]">0<span class="text-[10px] sm:text-[12px] md:text-[14px] font-semibold">円</span></span></td>
                <td class="p-2 sm:p-3 md:p-4"><span class="font-[Roboto] text-[16px] sm:text-[22px] md:text-[32px] font-medium text-[#3e3e3e]">0<span class="text-[10px] sm:text-[12px] md:text-[14px] font-semibold">円</span></span></td>
              </tr>
              <tr>
                <th class="bg-white text-[11px] sm:text-[14px] md:text-[18px] font-bold p-2 sm:p-3 md:p-4 sticky left-0 z-[3]">出張料金</th>
                <td class="bg-[#ffffdb] p-2 sm:p-3 md:p-4"><span class="font-[Roboto] text-[20px] sm:text-[28px] md:text-[40px] font-black text-[#ff4176]">0<span class="text-[10px] sm:text-[12px] md:text-[14px] font-semibold">円</span></span></td>
                <td class="p-2 sm:p-3 md:p-4"><span class="font-[Roboto] text-[16px] sm:text-[22px] md:text-[32px] font-medium text-[#3e3e3e]">0<span class="text-[10px] sm:text-[12px] md:text-[14px] font-semibold">円</span></span></td>
                <td class="p-2 sm:p-3 md:p-4"><span class="font-[Roboto] text-[16px] sm:text-[22px] md:text-[32px] font-medium text-[#3e3e3e]">0<span class="text-[10px] sm:text-[12px] md:text-[14px] font-semibold">円</span></span></td>
              </tr>
              <tr class="bg-[#f0f0f0]">
                <th class="bg-[#f0f0f0] text-[11px] sm:text-[14px] md:text-[18px] font-bold p-2 sm:p-3 md:p-4 sticky left-0 z-[3]">早朝深夜料金</th>
                <td class="bg-[#f5f5c4] p-2 sm:p-3 md:p-4"><span class="font-[Roboto] text-[20px] sm:text-[28px] md:text-[40px] font-black text-[#ff4176]">0<span class="text-[10px] sm:text-[12px] md:text-[14px] font-semibold">円</span></span></td>
                <td class="p-2 sm:p-3 md:p-4"><span class="font-[Roboto] text-[16px] sm:text-[22px] md:text-[32px] font-medium text-[#3e3e3e]">0<span class="text-[10px] sm:text-[12px] md:text-[14px] font-semibold">円</span></span></td>
                <td class="p-2 sm:p-3 md:p-4"><span class="text-[11px] sm:text-[14px] md:text-[18px] font-bold text-[#3e3e3e]">別途必要</span></td>
              </tr>
              <tr>
                <th class="bg-white text-[11px] sm:text-[14px] md:text-[18px] font-bold p-2 sm:p-3 md:p-4 sticky left-0 z-[3]">年間対応実績</th>
                <td class="bg-[#ffffdb] p-2 sm:p-3 md:p-4"><span class="font-[Roboto] text-[20px] sm:text-[28px] md:text-[40px] font-black text-[#ff4176]">15,000<span class="text-[10px] sm:text-[12px] md:text-[14px] font-semibold">件</span></span></td>
                <td class="p-2 sm:p-3 md:p-4"><span class="font-[Roboto] text-[16px] sm:text-[22px] md:text-[32px] font-medium text-[#3e3e3e]">100,000<span class="text-[10px] sm:text-[12px] md:text-[14px] font-semibold">件</span></span></td>
                <td class="p-2 sm:p-3 md:p-4"><span class="font-[Roboto] text-[16px] sm:text-[22px] md:text-[32px] font-medium text-[#3e3e3e]">30,000<span class="text-[10px] sm:text-[12px] md:text-[14px] font-semibold">件</span></span></td>
              </tr>
              <tr class="bg-[#f0f0f0]">
                <th class="bg-[#f0f0f0] text-[11px] sm:text-[14px] md:text-[18px] font-bold p-2 sm:p-3 md:p-4 sticky left-0 z-[3] rounded-bl-lg">即日対応</th>
                <td class="bg-[#f5f5c4] p-2 sm:p-3 md:p-4"><span class="font-[Roboto] text-[24px] sm:text-[32px] md:text-[40px] font-bold text-[#ff4176]">〇</span></td>
                <td class="p-2 sm:p-3 md:p-4"><span class="font-[Roboto] text-[24px] sm:text-[32px] md:text-[48px] font-light text-[#3e3e3e]">×</span></td>
