---
import { getImage } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCarousel from '../components/HeroCarousel.tsx';
import ServiceSlider from '../components/ServiceSlider.tsx';
import ReasonsGrid from '../components/ReasonsGrid.astro';
import ProcessFlow from '../components/ProcessFlow.astro';
import AreaMap from '../components/AreaMap.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import CTABlock from '../components/CTABlock.astro';
import ContactFormSection from '../components/ContactFormSection.astro';
import { SERVICE_CATEGORIES, REGIONAL_OFFICES, SITE_CONFIG } from '../utils/siteConfig';
import { generateLocalBusiness, generateFAQ } from '../utils/schema';
import { getCollection } from 'astro:content';
import { resolveImage } from '../utils/imageImports';

const allCases = await getCollection('cases');
const featuredCases = allCases
  .sort((a, b) => new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime())
  .slice(0, 4);

const allTestimonials = await getCollection('testimonials');
const featuredTestimonials = allTestimonials.slice(0, 4);

const allFaq = await getCollection('faq');
const sortedFaq = allFaq.sort((a, b) => a.data.sortOrder - b.data.sortOrder);

const categoryLabelMap = {
  water: '水まわり',
  electricity: '電気まわり',
} satisfies Record<'water' | 'electricity', string>;

const caseImagePaths: Record<string, string> = {
  'case-001': '/images/cases/case_01.jpg',
  'case-002': '/images/cases/case_02.jpg',
  'case-003': '/images/cases/case_03.jpg',
  'case-004': '/images/cases/case_04.jpg',
  'case-005': '/images/cases/case_05.jpg',
};

const testimonialImagePaths: Record<string, string> = {
  'testimonial-001': '/images/cases/case_01.jpg',
  'testimonial-002': '/images/cases/case_05.jpg',
  'testimonial-003': '/images/cases/case_03.jpg',
  'testimonial-004': '/images/cases/case_02.jpg',
};

async function optimizeImageMap(map: Record<string, string>, w: number, h: number) {
  const result: Record<string, string> = {};
  for (const [key, path] of Object.entries(map)) {
    const meta = await resolveImage(path);
    if (meta) {
      const opt = await getImage({ src: meta, width: w, height: h, format: 'webp', quality: 80 });
      result[key] = opt.src;
    } else {
      result[key] = path;
    }
  }
  return result;
}

const caseImageMap = await optimizeImageMap(caseImagePaths, 300, 300);
const testimonialImageMap = await optimizeImageMap(testimonialImagePaths, 300, 300);

const electricity = SERVICE_CATEGORIES.find((c) => c.slug === 'electricity');
const water = SERVICE_CATEGORIES.find((c) => c.slug === 'water');
if (!electricity || !water) {
  throw new Error('Missing required service category in SERVICE_CATEGORIES');
}

const imageMap: Record<string, Record<string, string>> = {
  electricity: {
    breaker: '/images/services/electricity_01.jpg',
    outlet: '/images/services/electricity_02.jpg',
    lighting: '/images/services/electricity_03.jpg',
    antenna: '/images/services/electricity_04.jpg',
    'water-heater': '/images/services/electricity_05.jpg',
  },
  water: {
    toilet: '/images/services/sanitary_01.jpg',
    kitchen: '/images/services/sanitary_02.jpg',
    bath: '/images/services/sanitary_03.jpg',
    washroom: '/images/services/sanitary_04.jpg',
  },
};

const altMap: Record<string, Record<string, string>> = {
  electricity: {
    breaker: 'ブレーカー修理・交換サービス',
    outlet: 'コンセント修理・交換サービス',
    lighting: '照明修理・交換サービス',
    antenna: 'アンテナ工事サービス',
    'water-heater': '給湯器交換サービス',
  },
  water: {
    toilet: 'トイレ修理サービス',
    kitchen: 'キッチン水漏れ修理サービス',
    bath: 'お風呂修理サービス',
    washroom: '洗面所修理サービス',
  },
};

const sliderImageOptMap = await optimizeImageMap(
  Object.fromEntries(
    Object.entries(imageMap).flatMap(([cat, slugs]) =>
      Object.entries(slugs).map(([slug, src]) => [`${cat}/${slug}`, src])
    )
  ),
  300, 300
);

const buildSlides = (category: typeof electricity) => {
  return category.subServices.map((s) => ({
    slug: s.slug,
    label: s.label,
    href: s.href,
    description: s.description,
    startingPrice: s.startingPrice,
    imageSrc: sliderImageOptMap[`${category.slug}/${s.slug}`] ?? imageMap[category.slug]?.[s.slug] ?? '/images/services/electricity_01.jpg',
    imageAlt: altMap[category.slug]?.[s.slug] ?? s.label,
  }));
};

const electricitySlides = buildSlides(electricity);
const waterSlides = buildSlides(water);

if (!REGIONAL_OFFICES.length) throw new Error('REGIONAL_OFFICES must not be empty');
const localBusinessSchema = generateLocalBusiness({
  ...REGIONAL_OFFICES[0],
  url: SITE_CONFIG.siteUrl,
  openingHours: ['Mo-Su 00:00-23:59'],
});

const faqSchema = sortedFaq.length > 0
  ? generateFAQ(sortedFaq.map((e) => ({ question: e.data.question, answer: e.data.answer })))
  : null;

const heroSlideData = [
  { image: '/images/hero/hero-01.jpeg', imageSp: '/images/hero/hero-01.jpeg', alt: '緊急の電気トラブル 設備プロの電気工事士が年中無休・即対応' },
  { image: '/images/hero/hero-02.jpeg', imageSp: '/images/hero/hero-02.jpeg', alt: '水道修理のプロが即駆けつけます。水漏れ・つまりを設備プロの職人が24時間スピード解決' },
];
const optimizedHeroSlides = await Promise.all(
  heroSlideData.map(async (slide) => {
    const desktopMeta = await resolveImage(slide.image);
    const mobileMeta = await resolveImage(slide.imageSp);
    const desktopOpt = desktopMeta ? await getImage({ src: desktopMeta, format: 'webp', quality: 80 }) : null;
    const mobileOpt = mobileMeta ? await getImage({ src: mobileMeta, format: 'webp', quality: 80 }) : null;
    return {
      image: desktopOpt?.src ?? slide.image,
      imageSp: mobileOpt?.src ?? slide.imageSp,
      alt: slide.alt,
    };
  })
);
---

<BaseLayout
  title="設備プロ（セツビプロ）｜水漏れ・電気修理｜24時間対応"
  description="水漏れ・電気トラブルなら設備プロ（セツビプロ）。24時間365日、全国対応。まずはお気軽にお電話ください。"
  canonicalUrl={SITE_CONFIG.siteUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  <h1 class="sr-only">設備プロ（セツビプロ）｜水漏れ・つまり・電気トラブルの修理を24時間365日対応する専門業者</h1>
  <HeroCarousel client:load slides={optimizedHeroSlides} />
  <ServiceSlider
    client:load
    slides={electricitySlides}
    heading="電気まわりの修理サービス"
    subheading="ブレーカー・コンセント・照明などの電気まわりトラブル解消。安心の事前見積りと24時間即対応"
    englishLabel="Electricity"
    bgColor="#fbc101"
    aboveFold
  />
  <ServiceSlider
    client:visible
    slides={waterSlides}
    heading="水まわりの修理サービス"
    subheading="トイレ・お風呂・キッチンなどの水回りのつまり・水漏れ修理。安心の事前見積りと24時間即対応"
    englishLabel="Sanitary"
    bgColor="#3ea6ff"
  />
  <ReasonsGrid />

  <!-- Consultation Fee Section -->
  <section class="pb-4 sm:pb-6 md:pb-8">
    <div class="max-w-[1200px] mx-auto px-3 sm:px-4">
      <div class="bg-[#fbc101] rounded-[24px] sm:rounded-[32px] md:rounded-[40px] p-5 sm:p-8 md:p-12 overflow-hidden">
        <h2 class="text-[18px] sm:text-[24px] md:text-[32px] font-extrabold text-center underline decoration-[#feff00] decoration-4 underline-offset-[13px]">
          <span class="text-[#ff4176]">ご相談無料！</span>必ず事前にお見積り
        </h2>
        <p class="text-[11px] sm:text-[12px] md:text-[14px] leading-relaxed mt-4 sm:mt-6 md:mt-8 text-center max-w-[800px] mx-auto" style="overflow-wrap:anywhere;word-break:break-word;">
          作業費+材料費部品代+処分費(※)で作業料金を算出いたします。<br />
          それ以外にかかる見積り費や出張費、早朝・深夜料金、キャンセル料は一切いただきません。
        </p>
        <figure class="mt-4 sm:mt-6 md:mt-8 max-w-[600px] mx-auto">
          <picture>
            <source media="(max-width: 900px)" srcset="/images/cta/cta_feature_sp.svg" />
            <source media="(min-width: 901px)" srcset="/images/cta/cta_feature.svg" />
            <img src="/images/cta/cta_feature.svg" alt="見積り無料・出張費無料・キャンセル料無料" loading="lazy" decoding="async" class="w-full h-auto" />
          </picture>
        </figure>
      </div>
    </div>
  </section>

  <!-- Staff Qualifications -->
  <section class="py-12 md:py-16 lg:py-20">
    <div class="max-w-[1200px] mx-auto px-3 sm:px-4">
      <div class="flex justify-center">
        <div class="w-full max-w-[585px] rounded-[24px] sm:rounded-[32px] md:rounded-[40px] bg-cover bg-center bg-no-repeat flex flex-col items-center justify-center py-10 sm:py-12 md:py-[51px] px-4" style="background-image: url('/images/staff_bg.jpg');">
          <p class="text-[16px] sm:text-[18px] md:text-[22px] font-bold text-white text-center">電気関連有資格</p>
          <div class="flex flex-col gap-2 mt-5 sm:mt-6 md:mt-7 w-fit mx-auto">
            <div class="flex items-center">
              <p class="w-[180px] sm:w-[190px] md:w-[204px] h-[24px] sm:h-[25px] md:h-[27px] bg-white rounded-[13px] text-[11px] sm:text-[11px] md:text-[12px] font-bold text-[#333] flex items-center justify-center">第1種電気工事士</p>
            </div>
            <div class="flex items-center">
              <p class="w-[180px] sm:w-[190px] md:w-[204px] h-[24px] sm:h-[25px] md:h-[27px] bg-white rounded-[13px] text-[11px] sm:text-[11px] md:text-[12px] font-bold text-[#333] flex items-center justify-center">第2種電気工事士</p>
            </div>
            <div class="flex items-center">
              <p class="w-[180px] sm:w-[190px] md:w-[204px] h-[24px] sm:h-[25px] md:h-[27px] bg-white rounded-[13px] text-[11px] sm:text-[11px] md:text-[12px] font-bold text-[#333] flex items-center justify-center">低圧電気取扱業務特別教育</p>
            </div>
          </div>
          <p class="text-[16px] sm:text-[18px] md:text-[22px] font-bold text-white text-center mt-8">水道関連有資格</p>
          <div class="flex flex-col gap-2 mt-5 sm:mt-6 md:mt-7 w-fit mx-auto">
            <div class="flex items-center">
              <p class="w-[180px] sm:w-[190px] md:w-[204px] h-[24px] sm:h-[25px] md:h-[27px] bg-white rounded-[13px] text-[11px] sm:text-[11px] md:text-[12px] font-bold text-[#333] flex items-center justify-center">給水装置工事主任技術者</p>
            </div>
            <div class="flex items-center">
              <p class="w-[180px] sm:w-[190px] md:w-[204px] h-[24px] sm:h-[25px] md:h-[27px] bg-white rounded-[13px] text-[11px] sm:text-[11px] md:text-[12px] font-bold text-[#333] flex items-center justify-center">管工事施工管理技士</p>
            </div>
            <div class="flex items-center">
              <p class="w-[180px] sm:w-[190px] md:w-[204px] h-[24px] sm:h-[25px] md:h-[27px] bg-white rounded-[13px] text-[11px] sm:text-[11px] md:text-[12px] font-bold text-[#333] flex items-center justify-center">排水設備工事責任技術者</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ProcessFlow />
  <AreaMap />

  <!-- Sales Office Section -->
  <section class="pt-[30px] pb-[80px] md:pb-[80px]">
    <div class="max-w-[1240px] mx-auto px-[20px]">
      <div class="bg-[#f7f7f7] rounded-[20px] md:rounded-[40px] px-[20px] pb-[45px] md:pb-[80px]">
        <h2 class="text-[24px] md:text-[42px] font-bold relative isolate flex flex-col items-center text-center pl-[10px] mb-[12px]">
          <span class="block w-[2px] h-[40px] md:h-[70px] bg-[#fbc102]"></span>
          営業所
        </h2>
        <div>
          <div class="py-[14px] border-b border-[#e9e9e9] w-full md:w-1/2 mx-auto">
            <span class="inline-block w-auto md:w-[140px] font-bold text-[#0044f2] text-[14px] md:text-base">関東営業所</span>
            <span class="text-[14px] md:text-base">準備中</span>
          </div>
          <div class="py-[14px] border-b border-[#e9e9e9] w-full md:w-1/2 mx-auto">
            <span class="inline-block w-auto md:w-[140px] font-bold text-[#0044f2] text-[14px] md:text-base">東海営業所</span>
            <span class="text-[14px] md:text-base">愛知県北名古屋市井瀬木1068-205</span>
          </div>
          <div class="py-[14px] border-b border-[#e9e9e9] w-full md:w-1/2 mx-auto">
            <span class="inline-block w-auto md:w-[140px] font-bold text-[#0044f2] text-[14px] md:text-base">中国営業所</span>
            <span class="text-[14px] md:text-base">広島県広島市西区中広2丁目19-33</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTABlock variant="full-width" />

  <!-- Case Studies Section -->
  <section class="py-12 md:py-16 lg:py-20">
    <div class="max-w-[1200px] mx-auto px-3 sm:px-4">
      <h2 class="text-[24px] md:text-[42px] font-bold relative isolate flex flex-col items-center text-center">
        <span class="block w-[2px] h-[40px] md:h-[70px] bg-[#fbc102]"></span>
        <span class="absolute top-[40px] md:top-[45px] left-1/2 -translate-x-1/2 opacity-30 font-[Roboto] text-[70px] md:text-[180px] font-bold text-[#b3b3b3] whitespace-nowrap -z-[1] pointer-events-none">Case</span>
        修理実績のご紹介
      </h2>
      <p class="text-center text-[11px] sm:text-[12px] md:text-[14px] text-[#333] mt-[20px] sm:mt-[30px] md:mt-[50px]">ご好評頂いたお客様の修理実績をご紹介</p>
      <div class="swiper homeCaseSwiper mt-[15px] sm:mt-[20px] md:mt-[50px] overflow-hidden pb-3">
        <div class="swiper-wrapper items-stretch">
          {featuredCases.map((entry) => (
            <div class="swiper-slide !h-auto">
              <CaseStudyCard
                title={entry.data.title}
                serviceCategory={entry.data.serviceCategory}
                categoryLabel={categoryLabelMap[entry.data.serviceCategory] ?? entry.data.serviceCategory}
                location={entry.data.location}
                duration={entry.data.duration}
                cost={entry.data.cost}
                description={entry.body ?? ''}
                imageSrc={caseImageMap[entry.id] ?? '/images/cases/case_01.jpg'}
                imageAlt={entry.data.imageAlt}
                slug={entry.id}
              />
            </div>
          ))}
        </div>
      </div>
      <div class="flex justify-center mt-[20px] sm:mt-[30px] md:mt-[42px]">
        <a href="/case" class="relative flex items-center justify-center w-[200px] sm:w-[240px] md:w-[280px] min-h-[45px] sm:min-h-[50px] md:min-h-[60px] bg-[#0044f2] text-white text-[12px] sm:text-[14px] md:text-[18px] font-bold rounded-[20px] sm:rounded-[25px] md:rounded-[30px] shadow-[0_5px_0_0_rgba(0,0,0,0.30)] hover:translate-y-[3px] hover:shadow-none transition-all duration-200">
          修理実績一覧
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="py-12 md:py-16 lg:py-20 bg-[#f5f5f5]">
    <div class="max-w-[1200px] mx-auto px-3 sm:px-4">
      <h2 class="text-[24px] md:text-[42px] font-bold relative isolate flex flex-col items-center text-center">
        <span class="block w-[2px] h-[40px] md:h-[70px] bg-[#fbc102]"></span>
        <span class="absolute top-[40px] md:top-[45px] left-1/2 -translate-x-1/2 opacity-30 font-[Roboto] text-[70px] md:text-[180px] font-bold text-[#b3b3b3] whitespace-nowrap -z-[1] pointer-events-none">Voice</span>
        お客様の声のご紹介
      </h2>
      <p class="text-center text-[11px] sm:text-[12px] md:text-[14px] text-[#333] mt-[20px] sm:mt-[30px] md:mt-[50px]">お客様の声のご紹介</p>
      <div class="swiper homeVoiceSwiper mt-[15px] sm:mt-[20px] md:mt-[50px] overflow-hidden pb-3">
        <div class="swiper-wrapper items-stretch">
          {featuredTestimonials.map((entry) => (
            <div class="swiper-slide !h-auto">
              <TestimonialCard
                serviceType={entry.data.serviceType}
                serviceCategory={entry.data.serviceCategory}
                cost={entry.data.cost}
                message={entry.data.message}
                authorInitial={entry.data.authorInitial}
                location={entry.data.location}
                imageSrc={testimonialImageMap[entry.id] ?? '/images/cases/case_01.jpg'}
                imageAlt={`${entry.data.serviceType}のお客様の声`}
              />
            </div>
          ))}
        </div>
      </div>
      <div class="flex justify-center mt-[20px] sm:mt-[30px] md:mt-[42px]">
        <a href="/voice" class="relative flex items-center justify-center w-[200px] sm:w-[240px] md:w-[280px] min-h-[45px] sm:min-h-[50px] md:min-h-[60px] bg-[#0044f2] text-white text-[12px] sm:text-[14px] md:text-[18px] font-bold rounded-[20px] sm:rounded-[25px] md:rounded-[30px] shadow-[0_5px_0_0_rgba(0,0,0,0.30)] hover:translate-y-[3px] hover:shadow-none transition-all duration-200">
          お客様の声一覧
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-12 md:py-16 lg:py-20">
    <div class="max-w-[1200px] mx-auto px-3 sm:px-4">
      <h2 class="text-[24px] md:text-[42px] font-bold relative isolate flex flex-col items-center text-center">
        <span class="block w-[2px] h-[40px] md:h-[70px] bg-[#fbc102]"></span>
        <span class="absolute top-[40px] md:top-[45px] left-1/2 -translate-x-1/2 opacity-30 font-[Roboto] text-[70px] md:text-[180px] font-bold text-[#b3b3b3] whitespace-nowrap -z-[1] pointer-events-none">Faq</span>
        よくいただくご質問
      </h2>
      <div id="faq-container">
        <div id="faq-visible">
          <FAQAccordion items={sortedFaq.slice(0, 5).map((entry) => ({ question: entry.data.question, answer: entry.data.answer }))} />
        </div>
        {sortedFaq.length > 5 && (
          <div id="faq-hidden" class="hidden">
            <FAQAccordion items={sortedFaq.slice(5).map((entry) => ({ question: entry.data.question, answer: entry.data.answer }))} />
          </div>
        )}
        {sortedFaq.length > 5 && (
          <div class="flex justify-center mt-[16px]">
            <button
              id="faq-toggle"
              type="button"
              class="flex flex-col items-center gap-1 text-[13px] md:text-[15px] font-bold text-[#0044f2] cursor-pointer"
            >
              <span id="faq-toggle-text">もっと見る</span>
              <svg id="faq-toggle-icon" xmlns="http://www.w3.org/2000/svg" class="w-[20px] h-[20px] transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
          </div>
        )}
      </div>
      <div class="flex justify-center mt-[20px] sm:mt-[30px] md:mt-[42px]">
        <a href="/faq" class="relative flex items-center justify-center w-[200px] sm:w-[240px] md:w-[280px] min-h-[45px] sm:min-h-[50px] md:min-h-[60px] bg-[#0044f2] text-white text-[12px] sm:text-[14px] md:text-[18px] font-bold rounded-[20px] sm:rounded-[25px] md:rounded-[30px] shadow-[0_5px_0_0_rgba(0,0,0,0.30)] hover:translate-y-[3px] hover:shadow-none transition-all duration-200">
          もっと見る
        </a>
      </div>
    </div>
  </section>

  <!-- Contact Form Section -->
  <ContactFormSection variant="homepage" />

  <CTABlock variant="full-width" />

  <script>
    import Swiper from 'swiper';
    import { Autoplay } from 'swiper/modules';
    import 'swiper/css';

    new Swiper('.homeCaseSwiper', {
      modules: [Autoplay],
      loop: true,
      centeredSlides: true,
      slidesPerView: 1,
      spaceBetween: 20,
      speed: 1000,
      autoplay: { delay: 2500, disableOnInteraction: false },
      breakpoints: {
        650: { slidesPerView: 1.5, spaceBetween: 30 },
        901: { slidesPerView: 3, spaceBetween: 30 },
        1240: { slidesPerView: 3, spaceBetween: 45 },
      },
    });

    new Swiper('.homeVoiceSwiper', {
      modules: [Autoplay],
      loop: true,
      centeredSlides: true,
      slidesPerView: 1,
      spaceBetween: 20,
      speed: 1000,
      autoplay: { delay: 2500, disableOnInteraction: false },
      breakpoints: {
        650: { slidesPerView: 1.5, spaceBetween: 30 },
        901: { slidesPerView: 3, spaceBetween: 30 },
        1240: { slidesPerView: 3, spaceBetween: 45 },
      },
    });
  </script>

  <script>
    const toggle = document.getElementById('faq-toggle');
    const hidden = document.getElementById('faq-hidden');
    const icon = document.getElementById('faq-toggle-icon');
    const text = document.getElementById('faq-toggle-text');
    if (toggle && hidden && icon && text) {
      toggle.addEventListener('click', () => {
        const isHidden = hidden.classList.contains('hidden');
        hidden.classList.toggle('hidden');
        icon.style.transform = isHidden ? 'rotate(180deg)' : '';
        text.textContent = isHidden ? '閉じる' : 'もっと見る';
      });
    }
  </script>
</BaseLayout>
