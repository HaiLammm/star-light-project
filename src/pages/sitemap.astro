---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CTABlock from '../components/CTABlock.astro';
import { SITE_CONFIG, SERVICE_CATEGORIES } from '../utils/siteConfig';
import { getCollection } from 'astro:content';

const breadcrumbItems = [
  { label: 'TOP', href: '/' },
  { label: 'サイトマップ', href: '/sitemap' },
];

const allServices = await getCollection('services');

const servicesByCategory = SERVICE_CATEGORIES.map((cat) => ({
  label: cat.label,
  href: cat.href,
  services: allServices
    .filter((s) => s.data.category === cat.slug)
    .map((s) => ({ name: s.data.serviceNameShort, href: `${cat.href}/${s.data.slug}` })),
})).filter((cat) => cat.services.length > 0);

const companyPages = [
  { label: '会社案内', href: '/company' },
  { label: '企業理念', href: '/company/philosophy' },
  { label: '対応可能エリア', href: '/company/office' },
];

const utilityPages = [
  { label: '作業の流れ', href: '/flow' },
  { label: 'よくある質問', href: '/faq' },
  { label: 'お問い合わせ', href: '/contact' },
  { label: 'プライバシーポリシー', href: '/privacy' },
];
---

<BaseLayout
  title="サイトマップ｜設備人"
  description="設備人のサイトマップです。各ページへのリンクを一覧でご確認いただけます。"
  canonicalUrl={`${SITE_CONFIG.siteUrl}/sitemap`}
>
  <div class="max-w-[1200px] mx-auto px-4 pt-4 pb-2">
    <Breadcrumb items={breadcrumbItems} />
  </div>

  <!-- KV Banner -->
  <section class="bg-[#0044f2] h-[240px] relative flex items-center overflow-hidden">
    <div class="max-w-[1200px] mx-auto px-4 w-full relative">
      <h1 class="text-[48px] font-black text-white ml-[45px]">サイトマップ</h1>
      <p class="font-[Roboto] text-[120px] font-bold text-white opacity-20 absolute top-1/2 left-[20px] -translate-y-1/2 capitalize">Sitemap</p>
    </div>
  </section>

  <section class="py-[80px] md:py-[120px]">
    <div class="max-w-[1200px] mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-12">
        <!-- TOP -->
        <div>
          <h2 class="text-[18px] md:text-[22px] font-bold mb-4 pb-2 border-b-2 border-[#0044f2]">
            <a href="/" class="hover:text-[#0044f2] transition-colors">TOP</a>
          </h2>
        </div>

        <!-- Service Categories -->
        {servicesByCategory.map((cat) => (
          <div>
            <h2 class="text-[18px] md:text-[22px] font-bold mb-4 pb-2 border-b-2 border-[#0044f2]">
              <a href={cat.href} class="hover:text-[#0044f2] transition-colors">{cat.label}</a>
            </h2>
            <ul class="space-y-2">
              {cat.services.map((service) => (
                <li>
                  <a href={service.href} class="text-[14px] md:text-[16px] text-gray-700 hover:text-[#0044f2] transition-colors">
                    {service.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}

        <!-- Company -->
        <div>
          <h2 class="text-[18px] md:text-[22px] font-bold mb-4 pb-2 border-b-2 border-[#0044f2]">
            <a href="/company" class="hover:text-[#0044f2] transition-colors">会社案内</a>
          </h2>
          <ul class="space-y-2">
            {companyPages.map((page) => (
              <li>
                <a href={page.href} class="text-[14px] md:text-[16px] text-gray-700 hover:text-[#0044f2] transition-colors">
                  {page.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Utility Pages -->
        <div>
          <h2 class="text-[18px] md:text-[22px] font-bold mb-4 pb-2 border-b-2 border-[#0044f2]">
            ご利用案内
          </h2>
          <ul class="space-y-2">
            {utilityPages.map((page) => (
              <li>
                <a href={page.href} class="text-[14px] md:text-[16px] text-gray-700 hover:text-[#0044f2] transition-colors">
                  {page.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <CTABlock variant="full-width" />
</BaseLayout>
