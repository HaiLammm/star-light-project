---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import ContactFormSection from '../components/ContactFormSection.astro';
import { SITE_CONFIG } from '../utils/siteConfig';

const breadcrumbItems = [
  { label: 'TOP', href: '/' },
  { label: '無料相談', href: '/contact' },
];
---

<BaseLayout
  title="無料相談｜設備プロ"
  description="設備プロへの無料相談・お問い合わせはこちら。水漏れ・電気トラブルのご相談を24時間受付中。"
  canonicalUrl={`${SITE_CONFIG.siteUrl}/contact`}
>
  <!-- Breadcrumb -->
  <div class="max-w-[1200px] mx-auto px-4 pt-4 pb-2">
    <Breadcrumb items={breadcrumbItems} />
  </div>

  <!-- KV (Key Visual) Banner -->
  <section class="bg-[#0044f2] h-[160px] sm:h-[200px] md:h-[240px] relative flex items-center overflow-hidden">
    <div class="max-w-[1200px] mx-auto px-4 w-full relative">
      <h1 class="text-[24px] sm:text-[36px] md:text-[48px] font-black text-white ml-[16px] sm:ml-[30px] md:ml-[45px]">無料相談</h1>
      <p class="font-[Roboto] text-[60px] sm:text-[90px] md:text-[120px] font-bold text-white opacity-20 absolute top-1/2 left-[10px] sm:left-[15px] md:left-[20px] -translate-y-1/2 capitalize">contact</p>
    </div>
  </section>

  <!-- Contact Form Section -->
  <div class="py-[80px] md:py-[120px]">
    <ContactFormSection variant="page" />
  </div>

  <!-- Consultation Section -->
  <section class="pb-[80px] md:pb-[120px]">
    <div class="max-w-[1200px] mx-auto px-4">
      <div class="bg-[#fbc101] rounded-[20px] md:rounded-[40px] px-[16px] sm:px-[24px] md:px-[42px] py-[30px] sm:py-[40px] md:py-[58px] relative overflow-hidden">
        <div class="relative z-[2]">
          <h2 class="text-[24px] md:text-[32px] font-extrabold text-center underline underline-offset-[13px] decoration-[4px]">
            <span class="text-[#E53935]">ご相談無料！</span>必ず事前にお見積り
          </h2>
          <p class="mt-6 md:mt-8 text-[14px] md:text-[16px] text-[#333] leading-relaxed text-center max-w-[800px] mx-auto" style="overflow-wrap:anywhere;word-break:break-word;">
            作業費+材料費部品代+処分費(※)で作業料金を算出いたします。<br />
            それ以外にかかる見積り費や出張費、早朝・深夜料金、キャンセル料は一切いただきません。<br />
            作業前に必ずお見積りを提示しますので、まずは相談・見積もりご安心ください。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ link (merged from former nav item) -->
  <section class="pb-[80px] md:pb-[120px]">
    <div class="max-w-[1200px] mx-auto px-4 text-center">
      <p class="text-[15px] md:text-[17px] text-[#333]">
        お問い合わせの前に、よくいただくご質問もあわせてご確認ください。
      </p>
      <a
        href="/faq"
        class="inline-flex items-center justify-center gap-[8px] mt-[20px] min-w-[240px] md:min-w-[280px] min-h-[56px] px-[24px] bg-[#0277BD] text-white text-[15px] md:text-[18px] font-bold rounded-[30px] shadow-[0_5px_0_0_rgba(0,0,0,0.25)] hover:translate-y-[3px] hover:shadow-none transition-all duration-200"
      >
        よくある質問を見る
      </a>
    </div>
  </section>
</BaseLayout>
