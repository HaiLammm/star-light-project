---
import { getImage } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { formatDateDot } from '../../utils/formatters';
import { BLOG_CATEGORY_COLOR_MAP } from '../../data/blogData';
import { generateArticle, serializeJsonLd } from '../../utils/schema';
import { SITE_CONFIG } from '../../utils/siteConfig';
import { resolveImage } from '../../utils/imageImports';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  return allPosts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

// Mục lục: lấy H2/H3, đánh số khớp với numbering heading (.article-numbered)
let h2Count = 0;
let h3Count = 0;
const tocItems = headings
  .filter((h) => h.depth === 2 || h.depth === 3)
  .map((h) => {
    if (h.depth === 2) {
      h2Count += 1;
      h3Count = 0;
      return { ...h, number: `${h2Count}.` };
    }
    h3Count += 1;
    return { ...h, number: `${h2Count}-${h3Count}.` };
  });

const heroMeta = await resolveImage(post.data.image);
const heroOpt = heroMeta ? await getImage({ src: heroMeta, width: 800, height: 450, format: 'webp', quality: 80 }) : null;
const heroImageSrc = heroOpt?.src ?? post.data.image;

const badgeBg = BLOG_CATEGORY_COLOR_MAP[post.data.category] ?? 'bg-[#717070]';

const breadcrumbItems = [
  { label: 'TOP', href: '/' },
  { label: 'コラム', href: '/columns/' },
  { label: post.data.title, href: `/columns/${post.id}/` },
];

const articleSchema = generateArticle({
  title: post.data.title,
  publishedDate: post.data.publishedDate.toISOString(),
  author: SITE_CONFIG.companyName,
  description: post.data.description,
  url: `${SITE_CONFIG.siteUrl}/columns/${post.id}/`,
  image: post.data.image,
  modifiedDate: post.data.updatedDate?.toISOString(),
});
---

<BaseLayout title={`${post.data.title} | 設備プロ`} description={post.data.description} canonicalUrl={`${SITE_CONFIG.siteUrl}/columns/${post.id}/`}>
  <script type="application/ld+json" set:html={serializeJsonLd(articleSchema)} />

  <article class="py-[30px] sm:py-[40px] md:py-[60px]">
    <div class="max-w-[1180px] mx-auto px-3 sm:px-4">
      <Breadcrumb items={breadcrumbItems} />

      <div class="mt-[20px] sm:mt-[30px] md:mt-[40px] lg:flex lg:gap-[40px]">
        {tocItems.length > 1 && (
          <aside class="hidden lg:block lg:w-[320px] lg:shrink-0">
            <nav aria-label="目次" class="sticky top-[120px] max-h-[calc(100vh-140px)] overflow-y-auto rounded-[12px] border border-[#e0e0e0] bg-white p-[20px_22px]">
              <p class="text-[16px] font-bold mb-[14px] flex items-center gap-[8px]">
                <span class="inline-block w-[4px] h-[18px] bg-navy"></span>目次
              </p>
              <ul class="flex flex-col gap-[7px]">
                {tocItems.map((item) => (
                  <li class={item.depth === 3 ? 'pl-[22px]' : '[&:not(:first-child)]:mt-[9px]'}>
                    <a href={`#${item.slug}`} class="group flex items-baseline gap-[8px]">
                      <span class={`shrink-0 font-bold font-[Roboto] ${item.depth === 3 ? 'text-[12px] text-[#9aa9bd]' : 'text-[13px] text-navy'}`}>{item.number}</span>
                      <span class={`[text-wrap:pretty] leading-[1.6] group-hover:text-[#0277BD] group-hover:underline ${item.depth === 3 ? 'text-[13px] text-[#666]' : 'text-[14px] font-medium text-[#333]'}`}>{item.text}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </aside>
        )}

        <div class="lg:flex-1 lg:min-w-0 w-full max-w-[800px] mx-auto lg:mx-0">
          <div class="flex items-center gap-[10px] mb-[10px] sm:mb-[15px]">
            <span class={`inline-block ${badgeBg} text-white text-[10px] sm:text-[11px] md:text-[12px] font-bold px-[8px] py-[2px] rounded-[4px] sm:rounded-[5px]`}>{post.data.subcategory}</span>
            <time class="text-[12px] sm:text-[13px] md:text-[14px] text-[#888]" datetime={post.data.publishedDate.toISOString()}>
              {formatDateDot(post.data.publishedDate)}
            </time>
          </div>

          <h1 class="text-[20px] sm:text-[26px] md:text-[36px] font-bold leading-tight mb-[20px] sm:mb-[25px] md:mb-[30px]">
            {post.data.title}
          </h1>

          <figure class="w-full rounded-[12px] sm:rounded-[16px] md:rounded-[20px] overflow-hidden mb-[25px] sm:mb-[30px] md:mb-[40px]">
            <img
              src={heroImageSrc}
              alt={post.data.imageAlt}
              width="800"
              height="450"
              loading="eager"
              decoding="async"
              class="w-full h-auto object-cover"
            />
          </figure>

          {tocItems.length > 1 && (
            <nav aria-label="目次" class="lg:hidden mb-[25px] sm:mb-[30px] rounded-[12px] border border-[#e0e0e0] bg-white p-[16px_18px] sm:p-[20px_24px]">
              <p class="text-[15px] sm:text-[17px] font-bold mb-[10px] sm:mb-[14px] flex items-center gap-[8px]">
                <span class="inline-block w-[4px] h-[18px] bg-navy"></span>目次
              </p>
              <ul class="flex flex-col gap-[7px]">
                {tocItems.map((item) => (
                  <li class={item.depth === 3 ? 'pl-[22px] sm:pl-[26px]' : '[&:not(:first-child)]:mt-[9px]'}>
                    <a href={`#${item.slug}`} class="group flex items-baseline gap-[8px]">
                      <span class={`shrink-0 font-bold font-[Roboto] ${item.depth === 3 ? 'text-[12px] text-[#9aa9bd]' : 'text-[13px] sm:text-[14px] text-navy'}`}>{item.number}</span>
                      <span class={`[text-wrap:pretty] leading-[1.6] group-hover:text-[#0277BD] group-hover:underline ${item.depth === 3 ? 'text-[13px] sm:text-[14px] text-[#666]' : 'text-[14px] sm:text-[15px] font-medium text-[#333]'}`}>{item.text}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          )}

          <div class="article-numbered prose prose-lg max-w-none w-full
            [&_h2]:text-[21px] [&_h2]:sm:text-[24px] [&_h2]:md:text-[28px] [&_h2]:font-bold [&_h2]:mt-[32px] [&_h2]:mb-[15px] [&_h2]:border-l-[4px] [&_h2]:border-navy [&_h2]:pl-[12px] [&_h2]:leading-[1.5]
            [&_h3]:text-[18px] [&_h3]:sm:text-[20px] [&_h3]:md:text-[22px] [&_h3]:font-bold [&_h3]:mt-[24px] [&_h3]:mb-[10px] [&_h3]:leading-[1.5]
            [&_p]:text-[16px] [&_p]:md:text-[17px] [&_p]:leading-[1.85] [&_p]:mb-[16px] [&_p]:text-[#333]
            [&_ul]:list-disc [&_ul]:pl-[22px] [&_ul]:mb-[16px]
            [&_ol]:list-decimal [&_ol]:pl-[22px] [&_ol]:mb-[16px]
            [&_li]:text-[16px] [&_li]:md:text-[17px] [&_li]:leading-[1.85] [&_li]:text-[#333] [&_li]:mb-[6px]
          ">
            <Content />
          </div>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
