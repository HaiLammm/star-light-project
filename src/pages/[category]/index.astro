---
import { getImage } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import ServiceKV from '../../components/ServiceKV.astro';
import CtaFeatures from '../../components/CtaFeatures.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import CTABlock from '../../components/CTABlock.astro';
import { SITE_CONFIG, ELECTRICITY_SERVICES, WATER_SERVICES, REGIONAL_OFFICES } from '../../utils/siteConfig';
import { getCollection } from 'astro:content';
import { generateLocalBusiness, generateFAQ, serializeJsonLd } from '../../utils/schema';
import { resolveImage } from '../../utils/imageImports';

export async function getStaticPaths() {
  return [
    { params: { category: 'electricity' } },
    { params: { category: 'water' } },
  ];
}

const { category } = Astro.params;

const categoryLabels: Record<string, string> = {
  electricity: '電気まわり',
  water: '水まわり',
};

const categoryIntro: Record<string, { heading: string; text: string }> = {
  electricity: {
    heading: '電気まわりのトラブルなら\n設備プロにおまかせ',
    text: 'ブレーカーが頻繁に落ちる・照明がつかない・コンセントから異臭がするなど、電気まわりのトラブルは生活に大きな支障をきたします。放置すると感電・発煙・火災など重大事故につながるおそれがあります。\n\n24時間年中無休の設備プロなら、第1種・第2種電気工事士の有資格者が最短10分で駆けつけ、現場で安全確認と復旧作業を行います。お見積もり・キャンセル料は一切いただいておりません。',
  },
  water: {
    heading: '水まわりのトラブルなら\n設備プロにおまかせ',
    text: 'トイレのつまり・水漏れ、キッチンの排水トラブル、お風呂の故障など、水まわりのトラブルは日常生活に直結する問題です。\n\n設備プロなら24時間年中無休で、経験豊富なスタッフが迅速に駆けつけます。お見積もり・キャンセル料は一切いただいておりません。',
  },
};

const categoryServices = {
  electricity: ELECTRICITY_SERVICES,
  water: WATER_SERVICES,
} as const;

const categoryKvPhoto: Record<string, string> = {
  electricity: '/images/services/electricity_03.jpg',
  water: '/images/services/sanitary_02.jpg',
};

const categoryPricing: Record<string, { original: number; discounted: number; discount: number }> = {
  electricity: { original: 2600, discounted: 1300, discount: 1300 },
  water: { original: 8800, discounted: 5000, discount: 3800 },
};

const serviceImages: Record<string, Record<string, { src: string; alt: string }>> = {
  electricity: {
    breaker: { src: '/images/services/electricity_01.jpg', alt: 'ブレーカー修理・交換' },
    outlet: { src: '/images/services/electricity_02.jpg', alt: 'コンセント修理・交換' },
    lighting: { src: '/images/services/electricity_03.jpg', alt: '照明修理・交換' },
    antenna: { src: '/images/services/electricity_04.jpg', alt: 'アンテナ工事' },
    'water-heater': { src: '/images/services/electricity_05.jpg', alt: '給湯器交換' },
  },
  water: {
    toilet: { src: '/images/services/sanitary_01.jpg', alt: 'トイレ修理' },
    kitchen: { src: '/images/services/sanitary_02.jpg', alt: 'キッチン修理' },
    bath: { src: '/images/services/sanitary_03.jpg', alt: 'お風呂修理' },
    washroom: { src: '/images/services/sanitary_04.jpg', alt: '洗面所修理' },
  },
};

const serviceLabel = categoryLabels[category] ?? category;
const services = categoryServices[category as keyof typeof categoryServices] ?? [];

const serviceImageOptMap: Record<string, string> = {};
for (const [slug, imgData] of Object.entries(serviceImages[category] ?? {})) {
  const meta = await resolveImage(imgData.src);
  if (meta) {
    const opt = await getImage({ src: meta, width: 300, height: 300, format: 'webp', quality: 80 });
    serviceImageOptMap[slug] = opt.src;
  }
}
const kvPhoto = categoryKvPhoto[category] ?? categoryKvPhoto.electricity;
const pricing = categoryPricing[category] ?? categoryPricing.electricity;
const intro = categoryIntro[category] ?? categoryIntro.electricity;
const images = serviceImages[category] ?? {};

const breadcrumbItems = [
  { label: 'TOP', href: '/' },
  { label: `${serviceLabel}サービス`, href: '#' },
];

const allFaq = await getCollection('faq');
const categoryFaqMap: Record<string, string[]> = {
  electricity: ['electricity', 'pricing', 'general'],
  water: ['water', 'pricing', 'general'],
};
const relevantCategories = categoryFaqMap[category] ?? ['general', 'pricing'];
const faqItems = allFaq
  .filter((f) => relevantCategories.includes(f.data.category))
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder)
  .map((f) => ({ question: f.data.question, answer: f.data.answer }));

const pageTitle = `${serviceLabel}のトラブルなら${SITE_CONFIG.companyName}｜東京・名古屋・広島【年中無休・即対応】`;
const pageDescription = `${serviceLabel}のトラブルなら${SITE_CONFIG.companyName}。東京・名古屋・広島エリア対応。24時間365日、最短10分で駆けつけ。見積り・キャンセル料無料。`;

const localBusinessSchemas = REGIONAL_OFFICES.map((office) =>
  generateLocalBusiness({ ...office, url: SITE_CONFIG.siteUrl })
);
const hubFaqSchema = faqItems.length > 0 ? generateFAQ(faqItems) : null;
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalUrl={`${SITE_CONFIG.siteUrl}/${category}/`}>
  {localBusinessSchemas.map((schema) => (
    <script type="application/ld+json" set:html={serializeJsonLd(schema)} />
  ))}
  {hubFaqSchema && <script type="application/ld+json" set:html={serializeJsonLd(hubFaqSchema)} />}

  <!-- Breadcrumb -->
  <div class="max-w-[1200px] mx-auto px-3 sm:px-4 py-3 sm:py-4">
    <Breadcrumb items={breadcrumbItems} />
  </div>

  <!-- KV (Key Visual) -->
  <ServiceKV
    accent={category as 'electricity' | 'water'}
    eyebrow={`${serviceLabel}の修理`}
    title={`${serviceLabel}のトラブル、プロが最短10分で駆けつけます。`}
    sub="見積り無料・出張費無料・キャンセル料無料。年中無休で対応します。"
    image={kvPhoto}
    imageAlt={`${serviceLabel}サービス`}
  />

  <!-- 24/7 Availability -->
  <div class="bg-[#1B2A4A] text-white text-center py-2 sm:py-3">
    <p class="text-[12px] sm:text-[14px] md:text-[16px] font-bold tracking-wide">
      <span class="inline-block bg-[#FF6B00] text-white text-[10px] sm:text-[11px] md:text-[13px] font-bold px-2 sm:px-3 py-0.5 sm:py-1 rounded-full mr-2 align-middle">24時間</span>
      <span class="align-middle">365日年中無休で対応 ｜ 電話相談無料</span>
    </p>
  </div>

  <!-- Price Bar -->
  <div class="bg-navy">
    <div class="max-w-[1240px] mx-auto px-3 sm:px-4 h-[60px] md:h-[100px] flex items-center justify-center">
      <div class="flex items-center gap-2 sm:gap-4 md:gap-6">
        <div class="bg-white rounded-[16px] sm:rounded-[20px] md:rounded-[22px] px-3 sm:px-6 md:px-8 py-1.5 sm:py-2 flex items-center gap-2 sm:gap-3">
          <span class="bg-black text-white text-[9px] sm:text-[11px] md:text-[14px] font-bold leading-tight px-2 sm:px-3 py-1 sm:py-1.5 rounded-[5px] flex items-center justify-center">WEB割引</span>
          <span class="font-[Roboto] text-[16px] sm:text-[22px] md:text-[29px] font-bold flex items-center">
            {pricing.discount.toLocaleString('ja-JP')}<span class="font-['Noto_Sans_JP'] text-[11px] sm:text-[14px] md:text-[19px] font-extrabold ml-0.5">円割引！</span>
          </span>
        </div>
        <div class="text-white text-center">
          <span class="block text-[10px] sm:text-[12px] md:text-[15px] font-extrabold">作業料金</span>
          <span class="text-[14px] sm:text-[18px] md:text-[23px] font-bold line-through decoration-white/60">{pricing.original.toLocaleString('ja-JP')}円</span>
        </div>
        <div class="w-[10px] sm:w-[14px] md:w-[17px] h-auto aspect-[17/41] bg-electric flex-shrink-0" style="clip-path: polygon(100% 50%, 0% 0%, 0% 100%);"></div>
        <p class="font-[Roboto] text-[28px] sm:text-[46px] md:text-[68px] font-black text-electric leading-none">
          {pricing.discounted.toLocaleString('ja-JP')}<span class="font-['Noto_Sans_JP'] text-[12px] sm:text-[16px] md:text-[21px] font-semibold text-white">円[税込]〜</span>
        </p>
      </div>
    </div>
  </div>

  <!-- Intro Section -->
  <section class="py-10 sm:py-14 md:py-20">
    <div class="max-w-[920px] mx-auto px-3 sm:px-4">
      <h1 class="text-[20px] sm:text-[26px] md:text-[32px] font-extrabold text-center pb-4 relative">
        {intro.heading.split('\n').map((line, i) => (
          <Fragment>
            {i > 0 && <br />}
            {line}
          </Fragment>
        ))}
        <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[30px] sm:w-[35px] md:w-[40px] h-[2px] bg-navy"></span>
      </h1>
      <div class="text-[13px] sm:text-[14px] md:text-[16px] leading-[1.75] mt-6 sm:mt-8 md:mt-10 text-text-primary" style="word-break: keep-all; overflow-wrap: anywhere;">
        {intro.text.split('\n\n').map((paragraph) => (
          <p class="mb-4 last:mb-0">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- Consultation Section -->
  <section class="pb-4 sm:pb-6 md:pb-8">
    <div class="max-w-[1200px] mx-auto px-3 sm:px-4">
      <div class="rounded-[24px] sm:rounded-[32px] md:rounded-[40px] p-5 sm:p-8 md:p-12 overflow-hidden bg-white border border-border-warm shadow-[0_6px_24px_rgba(27,42,74,0.08)]">
        <h2 class="text-[18px] sm:text-[24px] md:text-[32px] font-extrabold text-center text-navy underline decoration-electric decoration-4 underline-offset-[13px]">
          <span class="text-cta">ご相談無料！</span>必ず事前にお見積り
        </h2>
        <p class="text-[11px] sm:text-[12px] md:text-[14px] leading-relaxed mt-4 sm:mt-6 md:mt-8 text-center max-w-[800px] mx-auto" style="overflow-wrap:anywhere;word-break:break-word;">
          作業費+材料費部品代+処分費(※)で作業料金を算出いたします。<br />
          それ以外にかかる見積り費や出張費、早朝・深夜料金、キャンセル料は一切いただきません。
        </p>
        <CtaFeatures class="mt-4 sm:mt-6 md:mt-8" />
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-10 sm:py-14 md:py-20">
    <div class="max-w-[1200px] mx-auto px-3 sm:px-4">
      <h2 class="text-[24px] md:text-[42px] font-bold relative isolate flex flex-col items-center text-center">
        <span class="block w-[2px] h-[40px] md:h-[70px] bg-navy"></span>
        {serviceLabel}サービス一覧
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-4 md:gap-5 mt-[20px] sm:mt-[30px] md:mt-[50px]">
        {services.map((s) => {
          const img = images[s.slug] ?? { src: '/images/services/electricity_01.jpg', alt: s.label };
          return (
            <a
              href={s.href}
              class="flex flex-col rounded-[20px] sm:rounded-[24px] md:rounded-[30px] overflow-hidden border border-border-warm shadow-[0_6px_24px_rgba(27,42,74,0.08)] hover:-translate-y-1 transition-transform duration-200 bg-white"
            >
              <figure class="w-full overflow-hidden" style="aspect-ratio: 1/1;">
                <img
                  src={serviceImageOptMap[s.slug] ?? img.src}
                  alt={img.alt}
                  width="300"
                  height="300"
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover"
                />
              </figure>
              <div class="px-3 sm:px-4 py-3 sm:py-4 text-center">
                <p class="text-[13px] sm:text-[15px] md:text-[18px] font-bold leading-snug">{s.label}トラブル</p>
                <p class="text-[10px] sm:text-[11px] md:text-[12px] text-[#666] mt-1">{s.description}</p>
                <div class="flex items-center justify-center gap-1.5 mt-2">
                  <span class="bg-[#E53935] text-white text-[8px] sm:text-[9px] md:text-[10px] font-bold px-1.5 sm:px-2 py-0.5 rounded-[4px] leading-tight whitespace-nowrap">WEB割引</span>
                  <p class="font-[Roboto] text-[18px] sm:text-[22px] md:text-[26px] font-bold text-cta leading-none">
                    {s.startingPrice.toLocaleString('ja-JP')}<span class="font-['Noto_Sans_JP'] text-[10px] sm:text-[11px] md:text-[12px] font-medium text-[#333] ml-0.5">円[税込]〜</span>
                  </p>
                </div>
              </div>
            </a>
          );
        })}
      </div>
      <p class="text-[10px] sm:text-[11px] md:text-[12px] text-[#888] mt-4 sm:mt-6 md:mt-8 text-center leading-relaxed">
        ※作業料金以外に、部品・部材費用、処分費用など別途費用が発生する場合がございます。<br />
        必ず作業前にお見積りいたします。
      </p>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-12 md:py-16 lg:py-20">
    <div class="max-w-[1200px] mx-auto px-3 sm:px-4">
      <h2 class="text-[24px] md:text-[42px] font-bold relative isolate flex flex-col items-center text-center">
        <span class="block w-[2px] h-[40px] md:h-[70px] bg-navy"></span>
        よくいただくご質問
      </h2>
      <FAQAccordion items={faqItems} />
      <div class="flex justify-center mt-[20px] sm:mt-[30px] md:mt-[42px]">
        <a href="/question" class="relative flex items-center justify-center w-[200px] sm:w-[240px] md:w-[280px] min-h-[45px] sm:min-h-[50px] md:min-h-[60px] bg-white border-2 border-navy text-navy text-[12px] sm:text-[14px] md:text-[18px] font-bold rounded-full hover:bg-navy hover:text-white transition-colors duration-200">
          もっと見る
        </a>
      </div>
    </div>
  </section>

  <!-- Business Locations -->
  <section class="pb-10 sm:pb-12 md:pb-16">
    <div class="max-w-[1200px] mx-auto px-3 sm:px-4">
      <h3 class="text-[14px] sm:text-[16px] md:text-[20px] font-bold text-center mb-4 sm:mb-5 md:mb-6">営業所</h3>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6">
        {[
          { name: '関東営業所', address: '準備中' },
          { name: '東海営業所', address: '愛知県北名古屋市井瀬木1068-205' },
          { name: '中国営業所', address: '広島県広島市西区 中広2丁目19-33' },
        ].map((office) => (
          <div class="bg-[#f7f7f7] rounded-[12px] sm:rounded-[16px] p-4 sm:p-5">
            <p class="text-[12px] sm:text-[13px] md:text-[15px] font-bold text-[#1c1c1c] mb-1">{office.name}</p>
            <p class="text-[11px] sm:text-[12px] md:text-[14px] text-[#555]">{office.address}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABlock variant="full-width" />
</BaseLayout>
