---
import { getImage } from 'astro:assets';
import { getCollection } from 'astro:content';
import { resolveImage } from '../../utils/imageImports';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import ServiceKV from '../../components/ServiceKV.astro';
import CtaFeatures from '../../components/CtaFeatures.astro';
import AnchorMenu from '../../components/AnchorMenu.astro';
import PricingTier from '../../components/PricingTier.astro';
import ReasonsGrid from '../../components/ReasonsGrid.astro';
import ProcessFlow from '../../components/ProcessFlow.astro';
import AreaMap from '../../components/AreaMap.astro';
import CaseStudyCard from '../../components/CaseStudyCard.astro';
import TestimonialCard from '../../components/TestimonialCard.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import CTABlock from '../../components/CTABlock.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import ServiceSlider from '../../components/ServiceSlider.tsx';
import { SITE_CONFIG, ELECTRICITY_SERVICES, WATER_SERVICES } from '../../utils/siteConfig';
import { formatDateDot } from '../../utils/formatters';
import { generateService, generateFAQ, serializeJsonLd, type FAQItem } from '../../utils/schema';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((entry) => ({
    params: { category: entry.data.category, service: entry.data.slug },
    props: { serviceData: entry.data },
  }));
}

const { serviceData } = Astro.props;
const { category } = Astro.params;

const allCases = await getCollection('cases');
const allTestimonials = await getCollection('testimonials');
const allBlogPosts = await getCollection('blog');
const recentColumns = allBlogPosts
  .sort((a, b) => new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime())
  .slice(0, 5);

const columnImageMap: Record<string, string> = {};
for (const article of recentColumns) {
  const meta = await resolveImage(article.data.image);
  if (meta) {
    const opt = await getImage({ src: meta, width: 350, height: 196, format: 'webp', quality: 80 });
    columnImageMap[article.id] = opt.src;
  }
}

const serviceName = serviceData.serviceNameShort;
const serviceLongName = serviceData.serviceName;

const categoryLabels: Record<string, string> = {
  electricity: '電気まわり',
  water: '水まわり',
};
const serviceCategory = categoryLabels[category] ?? category;

const originalPrice = serviceData.originalPrice;
const discountedPrice = serviceData.startingPrice;
const webDiscountAmount = serviceData.webDiscountAmount;

const categoryServices = {
  electricity: ELECTRICITY_SERVICES,
  water: WATER_SERVICES,
} as const;

const categoryKvFallback: Record<string, string> = {
  electricity: '/images/hero/hero-01.jpeg',
  water: '/images/hero/hero-02.jpeg',
};
const breadcrumbItems = [
  { label: 'TOP', href: '/' },
  { label: `${serviceCategory}サービス`, href: `/${category}` },
  { label: `${serviceName}サービス`, href: '#' },
];

const anchorSections = [
  { id: 'price', label: '料金のご案内', icon: '/images/icons/anchor_icon_01.svg' },
  { id: 'reason', label: '選ばれる理由', icon: '/images/icons/anchor_icon_02.svg' },
  { id: 'compare', label: '他社比較', icon: '/images/icons/anchor_icon_03.svg' },
  { id: 'area', label: '対応エリア', icon: '/images/icons/anchor_icon_04.svg' },
  { id: 'flow', label: '作業の流れ', icon: '/images/icons/anchor_icon_05.svg' },
  { id: 'case', label: '修理事例', icon: '/images/icons/anchor_icon_06.svg' },
  { id: 'faq', label: 'FAQ', icon: '/images/icons/anchor_icon_07.svg' },
];

const rawPricingTiers = serviceData.pricingTiers;
const pricingTiers = await Promise.all(
  rawPricingTiers.map(async (tier: any) => {
    const meta = await resolveImage(tier.imageUrl);
    if (meta) {
      const opt = await getImage({ src: meta, width: 200, height: 160, format: 'webp', quality: 80 });
      return { ...tier, imageUrl: opt.src };
    }
    return tier;
  })
);
const faqItems = serviceData.faqEntries;

const relatedServiceImages: Record<string, { src: string; alt: string }> = {
  'breaker':      { src: '/images/services/electricity_01.jpg', alt: 'ブレーカー修理・交換サービス' },
  'outlet':       { src: '/images/services/electricity_02.jpg', alt: 'コンセント修理・交換サービス' },
  'lighting':     { src: '/images/services/electricity_03.jpg', alt: '照明修理・交換サービス' },
  'antenna':      { src: '/images/services/electricity_04.jpg', alt: 'アンテナ工事サービス' },
  'water-heater': { src: '/images/services/electricity_05.jpg', alt: '給湯器交換サービス' },
  'toilet':       { src: '/images/services/sanitary_01.jpg', alt: 'トイレ修理サービス' },
  'kitchen':      { src: '/images/services/sanitary_02.jpg', alt: 'キッチン修理サービス' },
  'bath':         { src: '/images/services/sanitary_03.jpg', alt: 'お風呂修理サービス' },
  'washroom':     { src: '/images/services/sanitary_04.jpg', alt: '洗面所修理サービス' },
};

const serviceImgOptMap: Record<string, string> = {};
for (const [slug, imgData] of Object.entries(relatedServiceImages)) {
  const meta = await resolveImage(imgData.src);
  if (meta) {
    const opt = await getImage({ src: meta, width: 300, height: 300, format: 'webp', quality: 80 });
    serviceImgOptMap[slug] = opt.src;
  }
}

const caseImageMap: Record<string, string> = {
  'toilet':       '/images/services/sanitary_01.jpg',
  'kitchen':      '/images/services/sanitary_02.jpg',
  'bath':         '/images/services/sanitary_03.jpg',
  'washroom':     '/images/services/sanitary_04.jpg',
  'breaker':      '/images/services/electricity_01.jpg',
  'outlet':       '/images/services/electricity_02.jpg',
  'lighting':     '/images/services/electricity_03.jpg',
  'antenna':      '/images/services/electricity_04.jpg',
  'water-heater': '/images/services/electricity_05.jpg',
};

const caseImgOptMap: Record<string, string> = {};
for (const [slug, path] of Object.entries(caseImageMap)) {
  const meta = await resolveImage(path);
  if (meta) {
    const opt = await getImage({ src: meta, width: 300, height: 300, format: 'webp', quality: 80 });
    caseImgOptMap[slug] = opt.src;
  }
}

const realCaseStudies = allCases
  .filter((c) => c.data.serviceCategory === category)
  .sort((a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime())
  .slice(0, 5)
  .map((c) => ({
    title: c.data.title,
    serviceCategory: c.data.serviceCategory as 'electricity' | 'water',
    categoryLabel: categoryLabels[c.data.serviceCategory] ?? c.data.serviceCategory,
    location: c.data.location,
    duration: c.data.duration,
    cost: c.data.cost,
    description: c.body ?? '',
    imageSrc: caseImgOptMap[c.data.serviceSlug] ?? caseImageMap[c.data.serviceSlug] ?? categoryKvFallback[c.data.serviceCategory],
    imageAlt: c.data.imageAlt,
    serviceSlug: c.data.serviceSlug,
  }));

const testimonialDetailMap: Record<string, { title: string; duration: string }> = {
  'testimonial-002': { title: '追いだき付き給湯器交換をご依頼いただいたお客様の声', duration: '180' },
  'testimonial-003': { title: 'ブースター工事をご依頼いただいたお客様の声', duration: '40' },
  'testimonial-005': { title: 'ガス給湯器交換をご依頼いただいたお客様の声', duration: '120' },
  'testimonial-006': { title: 'アンテナ工事をご依頼いただいたお客様の声', duration: '90' },
  'testimonial-007': { title: 'シーリング照明取付をご依頼いただいたお客様の声', duration: '30' },
  'testimonial-001': { title: 'トイレ修理をご依頼いただいたお客様の声', duration: '30' },
  'testimonial-004': { title: '洗面所つまり修理をご依頼いただいたお客様の声', duration: '20' },
};

const realTestimonials = allTestimonials
  .filter((t) => t.data.serviceCategory === category)
  .map((t) => ({
  serviceType: t.data.serviceType,
  serviceCategory: t.data.serviceCategory as 'electricity' | 'water',
  title: testimonialDetailMap[t.id]?.title ?? `${t.data.serviceType}をご依頼いただいたお客様の声`,
  duration: testimonialDetailMap[t.id]?.duration,
  cost: t.data.cost,
  message: t.data.message,
  authorInitial: t.data.authorInitial,
  location: t.data.location,
  imageSrc: serviceImgOptMap[t.data.serviceCategory === 'electricity' ? 'breaker' : t.data.serviceCategory === 'water' ? 'toilet' : 'cockroach'] ?? categoryKvFallback[t.data.serviceCategory] ?? categoryKvFallback['electricity'],
  imageAlt: `${t.data.serviceType}のお客様の声`,
}));

type CellValue =
  | { type: 'price'; amount: number }
  | { type: 'price-zero' }
  | { type: 'circle' }
  | { type: 'cross' }
  | { type: 'triangle' }
  | { type: 'text'; value: string };

interface ComparisonRow {
  label: string;
  our: CellValue;
  competitorA: CellValue;
  competitorB: CellValue;
}

const comparisonData: ComparisonRow[] = [
  { label: '作業料金', our: { type: 'price', amount: 4000 }, competitorA: { type: 'price', amount: 4000 }, competitorB: { type: 'price', amount: 4000 } },
  { label: '基本料金', our: { type: 'price-zero' }, competitorA: { type: 'price-zero' }, competitorB: { type: 'price-zero' } },
  { label: '出張料金', our: { type: 'price-zero' }, competitorA: { type: 'price-zero' }, competitorB: { type: 'price-zero' } },
  { label: '早朝深夜料金', our: { type: 'price-zero' }, competitorA: { type: 'price-zero' }, competitorB: { type: 'text', value: '別途必要' } },
  { label: '年間対応実績', our: { type: 'text', value: '15,000件' }, competitorA: { type: 'text', value: '100,000件' }, competitorB: { type: 'text', value: '30,000件' } },
  { label: '即日対応', our: { type: 'circle' }, competitorA: { type: 'cross' }, competitorB: { type: 'circle' } },
];


const categoryQualifications: Record<string, { title: string; items: string[] }> = {
  electricity: {
    title: '電気関連有資格',
    items: ['第1種電気工事士', '第2種電気工事士', '低圧電気取扱業務特別教育'],
  },
  water: {
    title: '水道関連有資格',
    items: ['給水装置工事主任技術者', '管工事施工管理技士', '排水設備工事責任技術者'],
  },
};
const qualifications = categoryQualifications[category] ?? { title: '有資格者', items: [] };

const currentCategoryServices = categoryServices[category as keyof typeof categoryServices] ?? [];
const relatedServices = currentCategoryServices
  .filter((s) => s.slug !== serviceData.slug)
  .slice(0, 4)
  .map((s) => ({
    ...s,
    imageSrc: serviceImgOptMap[s.slug] ?? relatedServiceImages[s.slug]?.src ?? categoryKvFallback[category],
    imageAlt: relatedServiceImages[s.slug]?.alt ?? `${s.label}サービス`,
  }));

const categorySliderSlides = currentCategoryServices.map((s) => ({
  slug: s.slug,
  label: s.label,
  href: s.href,
  description: s.description,
  startingPrice: s.startingPrice,
  imageSrc: serviceImgOptMap[s.slug] ?? relatedServiceImages[s.slug]?.src ?? categoryKvFallback[category],
  imageAlt: relatedServiceImages[s.slug]?.alt ?? s.label,
}));

const categorySliderConfig: Record<string, { heading: string; subheading: string; eyebrow: string; accent: 'electricity' | 'water' }> = {
  electricity: { heading: '電気まわりの修理サービス', subheading: 'ブレーカー・コンセント・照明などの電気まわりトラブル解消。安心の事前見積りと24時間即対応', eyebrow: '電気まわりの修理', accent: 'electricity' },
  water: { heading: '水まわりの修理サービス', subheading: 'トイレ・キッチン・お風呂などの水まわりトラブル解消。安心の事前見積りと24時間即対応', eyebrow: '水まわりの修理', accent: 'water' },
};
const sliderConfig = categorySliderConfig[category] ?? categorySliderConfig.electricity;

const pageTitle = `${serviceLongName}なら${SITE_CONFIG.companyName}【年中無休・即対応】`;
const pageDescription = serviceData.description;

const serviceSchema = generateService({
  serviceName: serviceLongName,
  description: serviceData.description,
  startingPrice: serviceData.startingPrice,
  serviceArea: serviceData.serviceArea ?? [],
  url: `${SITE_CONFIG.siteUrl}/${category}/${serviceData.slug}`,
  serviceType: serviceLongName,
});

const faqSchemaItems: FAQItem[] = (faqItems ?? []).map((item: { question: string; answer: string }) => ({
  question: item.question,
  answer: item.answer,
}));
const faqSchema = faqSchemaItems.length > 0 ? generateFAQ(faqSchemaItems) : null;
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalUrl={`${SITE_CONFIG.siteUrl}/${category}/${serviceData.slug}/`}>
  <script type="application/ld+json" set:html={serializeJsonLd(serviceSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={serializeJsonLd(faqSchema)} />}

  <!-- Section 1: Breadcrumb -->
  <div class="max-w-[1200px] mx-auto px-3 sm:px-4 py-3 sm:py-4">
    <Breadcrumb items={breadcrumbItems} />
  </div>

  <!-- Section 2: KV (Key Visual) -->
  <ServiceKV
    accent={category as 'electricity' | 'water'}
    eyebrow={`${serviceCategory}の修理`}
    title={`${serviceName}のトラブル、プロが最短10分で駆けつけます。`}
    sub="見積り無料・出張費無料・キャンセル料無料。年中無休で対応します。"
    image={relatedServiceImages[serviceData.slug]?.src ?? (category === 'electricity' ? '/images/services/electricity_01.jpg' : '/images/services/sanitary_01.jpg')}
    imageAlt={`${serviceLongName}サービス`}
  />

  <!-- KV Bottom: Price bar -->
  <div class="bg-navy">
    <div class="max-w-[1240px] mx-auto px-3 sm:px-4 h-[60px] md:h-[100px] flex items-center justify-center">
      <div class="flex items-center gap-1.5 sm:gap-4 md:gap-6">
        <div class="bg-white rounded-[16px] sm:rounded-[20px] md:rounded-[22px] px-2 sm:px-6 md:px-8 py-1 sm:py-2 flex items-center gap-1.5 sm:gap-3">
          <span class="shrink-0 bg-black text-white text-[9px] sm:text-[11px] md:text-[14px] font-bold leading-tight px-1.5 sm:px-3 py-1 sm:py-1.5 rounded-[5px] flex items-center justify-center">WEB割引</span>
          <span class="font-[Roboto] text-[clamp(13px,3.7vw,16px)] sm:text-[22px] md:text-[29px] font-bold flex items-baseline whitespace-nowrap">
            {webDiscountAmount.toLocaleString('ja-JP')}<span class="font-['Noto_Sans_JP'] text-[10px] sm:text-[14px] md:text-[19px] font-extrabold ml-0.5">円割引！</span>
          </span>
        </div>
        <div class="text-white text-center whitespace-nowrap">
          <span class="block text-[10px] sm:text-[12px] md:text-[15px] font-extrabold">作業料金</span>
          <span class="text-[13px] sm:text-[18px] md:text-[23px] font-bold line-through decoration-white/60">{originalPrice.toLocaleString('ja-JP')}円</span>
        </div>
        <div class="w-[9px] sm:w-[14px] md:w-[17px] h-auto aspect-[17/41] bg-electric flex-shrink-0" style="clip-path: polygon(100% 50%, 0% 0%, 0% 100%);"></div>
        <p class="font-[Roboto] text-[clamp(20px,6vw,28px)] sm:text-[46px] md:text-[68px] font-black text-electric leading-none whitespace-nowrap">
          {discountedPrice.toLocaleString('ja-JP')}<span class="font-['Noto_Sans_JP'] text-[10px] sm:text-[16px] md:text-[21px] font-semibold text-white">円[税込]〜</span>
        </p>
      </div>
    </div>
  </div>

  <!-- Intro Section -->
  <section class="py-10 sm:py-14 md:py-20">
    <div class="max-w-[920px] mx-auto px-3 sm:px-4">
      <h1 class="text-[20px] sm:text-[26px] md:text-[32px] font-extrabold text-center pb-4 relative">
        {serviceName}のトラブルなら<wbr />設備プロにおまかせ
        <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[30px] sm:w-[35px] md:w-[40px] h-[2px] bg-navy"></span>
      </h1>
      <div class="text-[13px] sm:text-[14px] md:text-[16px] leading-[1.75] mt-6 sm:mt-8 md:mt-10 text-text-primary" style="word-break: keep-all; overflow-wrap: anywhere;">
        {(serviceData.introText ?? serviceData.description).split('\n\n').map((paragraph: string) => (
          <p class="mb-4 last:mb-0">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- Consultation Section -->
  <section class="pb-4 sm:pb-6 md:pb-8">
    <div class="max-w-[1200px] mx-auto px-3 sm:px-4">
      <div class="bg-white border border-border-warm shadow-[0_6px_24px_rgba(27,42,74,0.08)] rounded-[24px] sm:rounded-[32px] md:rounded-[40px] p-5 sm:p-8 md:p-12 overflow-hidden">
        <h2 class="text-[clamp(15px,5.2vw,32px)] font-extrabold text-center text-navy">
          <span class="inline-block border-b-4 border-electric pb-[12px] whitespace-nowrap"><span class="text-cta">ご相談無料！</span>必ず事前にお見積り</span>
        </h2>
        <p class="text-[11px] sm:text-[12px] md:text-[14px] leading-relaxed mt-4 sm:mt-6 md:mt-8 text-center max-w-[800px] mx-auto" style="overflow-wrap:anywhere;word-break:break-word;">
          作業費+材料費部品代+処分費(※)で作業料金を算出いたします。<br />
          それ以外にかかる見積り費や出張費、早朝・深夜料金、キャンセル料は一切いただきません。
        </p>
        <CtaFeatures class="mt-4 sm:mt-6 md:mt-8" />
      </div>
    </div>
  </section>

  <!-- Anchor Menu -->
  <AnchorMenu sections={anchorSections} />

  <!-- Pricing Section -->
  <PricingTier tiers={pricingTiers} serviceName={`${serviceName}トラブル`} />

  <!-- Reasons Section -->
  <div id="reason">
    <ReasonsGrid />
  </div>

  <!-- Staff Qualifications -->
  <section class="py-12 md:py-16 lg:py-20">
    <div class="max-w-[1200px] mx-auto px-3 sm:px-4">
      <div class="flex justify-center">
        <div class="w-full max-w-[585px] rounded-[24px] sm:rounded-[32px] md:rounded-[40px] bg-cover bg-center bg-no-repeat flex flex-col items-center justify-center py-10 sm:py-12 md:py-[51px] px-4" style="background-image: url('/images/staff_bg.jpg');">
          <p class="text-[16px] sm:text-[18px] md:text-[22px] font-bold text-white text-center">{qualifications.title}</p>
          <div class="flex flex-col gap-2 mt-5 sm:mt-6 md:mt-7 w-fit mx-auto">
            {qualifications.items.map((item) => (
              <div class="flex items-center">
                <p class="w-[180px] sm:w-[190px] md:w-[204px] h-[24px] sm:h-[25px] md:h-[27px] bg-white rounded-[13px] text-[11px] sm:text-[11px] md:text-[12px] font-bold text-[#333] flex items-center justify-center">{item}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <ComparisonTable rows={comparisonData} />

  <!-- Service Area -->
  <div id="area">
    <AreaMap />
  </div>

  <!-- Process Flow -->
  <div id="flow">
    <ProcessFlow serviceName={serviceName} />
  </div>

  <!-- Business Locations -->
  <section class="pb-10 sm:pb-12 md:pb-16">
    <div class="max-w-[1200px] mx-auto px-3 sm:px-4">
      <h3 class="text-[14px] sm:text-[16px] md:text-[20px] font-bold text-center mb-4 sm:mb-5 md:mb-6">営業所</h3>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6">
        {[
          { name: '関東営業所', address: '準備中' },
          { name: '東海営業所', address: 'abcxyz' },
          { name: '中国営業所', address: 'abcxyz' },
        ].map((office) => (
          <div class="bg-[#f7f7f7] rounded-[12px] sm:rounded-[16px] p-4 sm:p-5">
            <p class="text-[12px] sm:text-[13px] md:text-[15px] font-bold text-[#1c1c1c] mb-1">{office.name}</p>
            <p class="text-[11px] sm:text-[12px] md:text-[14px] text-[#555]">{office.address}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Case Studies -->
  <section id="case" class="py-12 md:py-16 lg:pt-[80px] lg:pb-[120px]">
    <div class="max-w-[1200px] mx-auto px-3 sm:px-4">
      <h2 class="text-[24px] md:text-[42px] font-bold relative isolate flex flex-col items-center text-center">
        <span class="block w-[2px] h-[40px] md:h-[70px] bg-navy"></span>
        修理実績のご紹介
      </h2>
      <p class="text-center text-[11px] sm:text-[12px] md:text-[14px] text-[#333] mt-[20px] sm:mt-[30px] md:mt-[50px]">ご好評頂いたお客様の修理実績をご紹介</p>
      <div class="swiper caseSwiper mt-[15px] sm:mt-[20px] md:mt-[50px] overflow-hidden pb-3">
        <div class="swiper-wrapper items-stretch">
          {realCaseStudies.map((cs) => (
            <div class="swiper-slide !h-auto">
              <CaseStudyCard {...cs} />
            </div>
          ))}
        </div>
      </div>
      <div class="flex justify-center mt-[20px] sm:mt-[30px] md:mt-[42px]">
        <a href="/case" class="relative flex items-center justify-center w-[200px] sm:w-[240px] md:w-[280px] min-h-[45px] sm:min-h-[50px] md:min-h-[60px] bg-white border-2 border-navy text-navy text-[12px] sm:text-[14px] md:text-[18px] font-bold rounded-full hover:bg-navy hover:text-white transition-colors duration-200">
          修理実績一覧
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section id="voice" class="py-12 md:py-16 lg:pt-[80px] lg:pb-[120px]">
    <div class="max-w-[1200px] mx-auto px-3 sm:px-4">
      <h2 class="text-[24px] md:text-[42px] font-bold relative isolate flex flex-col items-center text-center">
        <span class="block w-[2px] h-[40px] md:h-[70px] bg-navy"></span>
        お客様の声のご紹介
      </h2>
      <p class="text-center text-[11px] sm:text-[12px] md:text-[14px] text-[#333] mt-[20px] sm:mt-[30px] md:mt-[50px]">お客様の声のご紹介</p>
      <div class="swiper voiceSwiper mt-[15px] sm:mt-[20px] md:mt-[50px] overflow-hidden pb-3">
        <div class="swiper-wrapper items-stretch">
          {realTestimonials.map((t) => (
            <div class="swiper-slide !h-auto">
              <TestimonialCard {...t} />
            </div>
          ))}
        </div>
      </div>
      <div class="flex justify-center mt-[20px] sm:mt-[30px] md:mt-[42px]">
        <a href="/voice" class="relative flex items-center justify-center w-[200px] sm:w-[240px] md:w-[280px] min-h-[45px] sm:min-h-[50px] md:min-h-[60px] bg-white border-2 border-navy text-navy text-[12px] sm:text-[14px] md:text-[18px] font-bold rounded-full hover:bg-navy hover:text-white transition-colors duration-200">
          お客様の声一覧
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="py-12 md:py-16 lg:py-20">
    <div class="max-w-[1200px] mx-auto px-3 sm:px-4">
      <h2 class="text-[24px] md:text-[42px] font-bold relative isolate flex flex-col items-center text-center">
        <span class="block w-[2px] h-[40px] md:h-[70px] bg-navy"></span>
        よくいただくご質問
      </h2>
      <FAQAccordion items={faqItems} />
      <div class="flex justify-center mt-[20px] sm:mt-[30px] md:mt-[42px]">
        <a href="/faq" class="relative flex items-center justify-center w-[200px] sm:w-[240px] md:w-[280px] min-h-[45px] sm:min-h-[50px] md:min-h-[60px] bg-white border-2 border-navy text-navy text-[12px] sm:text-[14px] md:text-[18px] font-bold rounded-full hover:bg-navy hover:text-white transition-colors duration-200">
          もっと見る
        </a>
      </div>
    </div>
  </section>

  <!-- Blog/Column Section -->
  <section class="py-12 md:py-16 lg:pt-[80px] lg:pb-[120px]">
    <div class="max-w-[1200px] mx-auto px-3 sm:px-4">
      <h2 class="text-[24px] md:text-[42px] font-bold relative isolate flex flex-col items-center text-center">
        <span class="block w-[2px] h-[40px] md:h-[70px] bg-navy"></span>
        <span><span class="font-[Roboto] mr-2">Column</span>お役立ち情報</span>
      </h2>
      <div class="swiper columnSwiper mt-[20px] sm:mt-[30px] md:mt-[50px] overflow-hidden pb-3">
        <div class="swiper-wrapper items-stretch">
          {recentColumns.map((article) => (
            <div class="swiper-slide !h-auto">
              <a href={`/columns/${article.id}/`} class="flex flex-col h-full rounded-[20px] sm:rounded-[30px] md:rounded-[40px] overflow-hidden border border-border-warm shadow-[0_6px_24px_rgba(27,42,74,0.08)] hover:-translate-y-1 transition-transform duration-200 bg-white">
                <figure class="w-full overflow-hidden" style="aspect-ratio: 350/196;">
                  <img src={columnImageMap[article.id] ?? article.data.image} alt={article.data.imageAlt} width="350" height="196" loading="lazy" decoding="async" class="w-full h-full object-cover" />
                </figure>
                <div class="px-[16px] pt-[16px] pb-[18px] sm:px-[24px] sm:pt-[20px] sm:pb-[24px] md:px-[30px] md:pt-[23px] md:pb-[28px]">
                  <span class="inline-block bg-water-tint text-water text-[10px] sm:text-[12px] md:text-[14px] font-bold px-3 py-1 rounded-b-[12px] sm:rounded-b-[16px] md:rounded-b-[20px] mb-2 sm:mb-3">{article.data.subcategory}</span>
                  <p class="text-[13px] sm:text-[15px] md:text-[18px] font-bold leading-snug line-clamp-2">{article.data.title}</p>
                  <p class="text-[11px] sm:text-[12px] md:text-[14px] text-[#888] mt-2">{formatDateDot(article.data.publishedDate)}</p>
                </div>
              </a>
            </div>
          ))}
        </div>
      </div>
      <div class="flex justify-center mt-[20px] sm:mt-[30px] md:mt-[42px]">
        <a href="/columns" class="relative flex items-center justify-center w-[200px] sm:w-[240px] md:w-[280px] min-h-[45px] sm:min-h-[50px] md:min-h-[60px] bg-white border-2 border-navy text-navy text-[12px] sm:text-[14px] md:text-[18px] font-bold rounded-full hover:bg-navy hover:text-white transition-colors duration-200">
          お役立ち情報一覧
        </a>
      </div>
    </div>
  </section>

  <!-- All Category Services -->
  <ServiceSlider
    client:visible
    slides={categorySliderSlides}
    heading={sliderConfig.heading}
    subheading={sliderConfig.subheading}
    eyebrow={sliderConfig.eyebrow}
    accent={sliderConfig.accent}
  />

  <!-- Final CTA -->
  <CTABlock variant="full-width" />

  <script>
    import 'swiper/css';
    import Swiper from 'swiper';
    import { Autoplay } from 'swiper/modules';

    const caseSwiper = new Swiper('.caseSwiper', {
      modules: [Autoplay],
      loop: true,
      centeredSlides: true,
      slidesPerView: 1,
      spaceBetween: 20,
      speed: 1000,
      autoplay: { delay: 2500, disableOnInteraction: false },
      breakpoints: {
        650: { slidesPerView: 1.5, spaceBetween: 30 },
        901: { slidesPerView: 3, spaceBetween: 30 },
        1240: { slidesPerView: 3, spaceBetween: 45 },
      },
    });

    const voiceSwiper = new Swiper('.voiceSwiper', {
      modules: [Autoplay],
      loop: true,
      centeredSlides: true,
      slidesPerView: 1,
      spaceBetween: 20,
      speed: 1000,
      autoplay: { delay: 2500, disableOnInteraction: false },
      breakpoints: {
        650: { slidesPerView: 1.5, spaceBetween: 30 },
        901: { slidesPerView: 3, spaceBetween: 30 },
        1240: { slidesPerView: 3, spaceBetween: 45 },
      },
    });

    const columnSwiper = new Swiper('.columnSwiper', {
      slidesPerView: 1.2,
      spaceBetween: 16,
      breakpoints: {
        640: { slidesPerView: 2.1, spaceBetween: 20 },
        1024: { slidesPerView: 3, spaceBetween: 24 },
      },
    });

  </script>
</BaseLayout>
