---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTABlock from '../../components/CTABlock.astro';
import { SITE_CONFIG, REGIONAL_OFFICES } from '../../utils/siteConfig';
import { getCollection } from 'astro:content';
import { generateLocalBusiness } from '../../utils/schema';

const companyEntries = await getCollection('company');
const philosophyEntry = companyEntries.find((e) => e.data.type === 'philosophy');
const data = philosophyEntry!.data;

const breadcrumbItems = [
  { label: 'TOP', href: '/' },
  { label: '会社案内', href: '/company' },
  { label: '企業理念', href: '/company/philosophy' },
];

const localBusinessSchemas = REGIONAL_OFFICES.map((office) =>
  generateLocalBusiness({ ...office, url: SITE_CONFIG.siteUrl })
);
---

<BaseLayout
  title="企業理念｜設備プロ"
  description="設備プロの企業理念。お客様の不安を1分でも早く取り除くため、優れた技術と心温まる接客で安心を提供します。"
  canonicalUrl={`${SITE_CONFIG.siteUrl}/company/philosophy`}
>
  {localBusinessSchemas.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}

  <!-- Breadcrumb -->
  <div class="max-w-[1200px] mx-auto px-4 pt-4 pb-2">
    <Breadcrumb items={breadcrumbItems} />
  </div>

  <!-- KV Banner -->
  <section class="bg-[#0044f2] h-[160px] sm:h-[200px] md:h-[240px] relative flex items-center overflow-hidden">
    <div class="max-w-[1200px] mx-auto px-4 w-full relative">
      <h1 class="text-[24px] sm:text-[36px] md:text-[48px] font-black text-white ml-[16px] sm:ml-[30px] md:ml-[45px]">企業理念</h1>
      <p class="font-[Roboto] text-[60px] sm:text-[90px] md:text-[120px] font-bold text-white opacity-20 absolute top-1/2 left-[10px] sm:left-[15px] md:left-[20px] -translate-y-1/2 capitalize whitespace-nowrap">philosophy</p>
    </div>
  </section>

  <!-- Hero Subheading -->
  <section class="py-[60px] md:py-[80px] bg-[#fbc102]">
    <div class="max-w-[1200px] mx-auto px-4 text-center">
      <p class="text-[24px] md:text-[36px] font-extrabold">{data.heroSubheading}</p>
    </div>
  </section>

  <!-- Philosophy Content -->
  <section class="py-[80px] md:py-[120px]">
    <div class="max-w-[800px] mx-auto px-4">
      <h2 class="text-[24px] md:text-[32px] font-extrabold text-center mb-10 md:mb-14">
        {data.sectionTitle}
      </h2>
      {data.sectionBody?.map((paragraph) => (
        <p class="text-[14px] md:text-[16px] leading-relaxed text-[#333] mb-6 last:mb-0">
          {paragraph}
        </p>
      ))}
    </div>
  </section>

  <!-- Promises -->
  <section class="py-[80px] md:py-[120px] bg-[#f5f5f5]">
    <div class="max-w-[1200px] mx-auto px-4">
      <h2 class="text-[24px] md:text-[32px] font-extrabold text-center mb-10 md:mb-14">
        お客様への{data.promises?.length}つのお約束
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {data.promises?.map((promise) => (
          <div class="bg-white rounded-2xl p-8 text-center shadow-sm">
            <div class="inline-flex items-center justify-center w-[60px] h-[60px] rounded-full bg-[#0044f2] text-white font-[Roboto] font-bold text-[20px] mb-6">
              {promise.number}
            </div>
            <p class="text-[16px] md:text-[18px] font-bold leading-relaxed">
              {promise.text}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Block -->
  <CTABlock variant="full-width" />
</BaseLayout>
