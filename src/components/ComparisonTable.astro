---
type CellValue =
  | { type: 'price'; amount: number }
  | { type: 'price-zero' }
  | { type: 'circle' }
  | { type: 'cross' }
  | { type: 'triangle' }
  | { type: 'text'; value: string };

interface ComparisonRow {
  label: string;
  our: CellValue;
  competitorA: CellValue;
  competitorB: CellValue;
}

interface Props {
  rows: ComparisonRow[];
  title?: string;
  caption?: string;
}

const {
  rows,
  title = '他社サービスと比較しました',
  caption = '設備プロと他社サービスの比較',
} = Astro.props;

---

<section id="compare" class="py-12 md:py-16 lg:py-20">
  <div class="max-w-[1200px] mx-auto px-3 sm:px-4">
    <div class="border-[6px] border-[#e5e5e5] rounded-[24px] sm:rounded-[32px] md:rounded-[40px] px-3 sm:px-6 md:px-10 pb-6 sm:pb-8 md:pb-10">
      <h2 class="text-[24px] md:text-[42px] font-bold relative isolate flex flex-col items-center text-center pt-8 sm:pt-10 md:pt-12 mb-6 sm:mb-8 md:mb-12">
        <span class="block w-[2px] h-[40px] md:h-[70px] bg-navy"></span>
        {title}
      </h2>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-center" style="table-layout: fixed; min-width: 500px;">
          <caption class="sr-only">{caption}</caption>
          <colgroup>
            <col />
            <col class="border-4 border-cta" />
            <col />
            <col />
          </colgroup>
          <thead>
            <tr>
              <th scope="col" class="bg-[#1c1c1c] text-white text-[11px] sm:text-[14px] md:text-[18px] font-bold p-2 sm:p-3 md:p-4 rounded-tl-lg"></th>
              <th scope="col" class="bg-[#1c1c1c] text-white p-2 sm:p-3 md:p-4">
                <img src="/images/site_logo_no-mark.jpeg" alt="設備プロ" class="w-[60px] sm:w-[80px] md:w-[100px] mx-auto" />
              </th>
              <th scope="col" class="bg-[#1c1c1c] text-white text-[11px] sm:text-[14px] md:text-[18px] font-bold p-2 sm:p-3 md:p-4">A社</th>
              <th scope="col" class="bg-[#1c1c1c] text-white text-[11px] sm:text-[14px] md:text-[18px] font-bold p-2 sm:p-3 md:p-4 rounded-tr-lg">B社</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((row, index) => {
              const isEven = index % 2 === 0;
              const isLast = index === rows.length - 1;
              const rowBg = isEven ? '' : 'bg-[#f0f0f0]';
              const thBg = isEven ? 'bg-white' : 'bg-[#f0f0f0]';
              const ourBg = isEven ? 'bg-[#ffffdb]' : 'bg-[#f5f5c4]';

              return (
                <tr class={rowBg}>
                  <th
                    scope="row"
                    class={`${thBg} text-[11px] sm:text-[14px] md:text-[18px] font-bold p-2 sm:p-3 md:p-4 sticky left-0 z-[3]${isLast ? ' rounded-bl-lg' : ''}`}
                  >
                    {row.label}
                  </th>
                  <td class={`${ourBg} p-2 sm:p-3 md:p-4`}>
                    {row.our.type === 'price' && (
                      <div class="flex flex-col items-center gap-1">
                        <span class="inline-flex items-center gap-1 bg-black text-white text-[8px] sm:text-[9px] md:text-[11px] font-bold px-1.5 sm:px-2 py-0.5 rounded-[4px]">
                          WEB割引<span class="text-electric ml-0.5">1,500円割引!</span>
                        </span>
                        <span class="font-[Roboto] text-[20px] sm:text-[28px] md:text-[40px] font-black text-cta">
                          {row.our.amount.toLocaleString('ja-JP')}<span class="text-[10px] sm:text-[12px] md:text-[14px] font-semibold">円[税込]〜</span>
                        </span>
                      </div>
                    )}
                    {row.our.type === 'price-zero' && (
                      <span class="font-[Roboto] text-[20px] sm:text-[28px] md:text-[40px] font-black text-cta">
                        0<span class="text-[10px] sm:text-[12px] md:text-[14px] font-semibold">円</span>
                      </span>
                    )}
                    {row.our.type === 'circle' && (
                      <span class="font-[Roboto] text-[24px] sm:text-[32px] md:text-[40px] font-bold text-cta" aria-label="対応">〇</span>
                    )}
                    {row.our.type === 'cross' && (
                      <span class="font-[Roboto] text-[24px] sm:text-[32px] md:text-[48px] font-light text-[#3e3e3e]" aria-label="非対応">×</span>
                    )}
                    {row.our.type === 'triangle' && (
                      <span class="font-[Roboto] text-[24px] sm:text-[32px] md:text-[40px] font-medium text-[#3e3e3e]" aria-label="要確認">△</span>
                    )}
                    {row.our.type === 'text' && (
                      <span class="font-[Roboto] text-[20px] sm:text-[28px] md:text-[40px] font-black text-cta">
                        {row.our.value}
                      </span>
                    )}
                  </td>
                  <td class="p-2 sm:p-3 md:p-4">
                    {row.competitorA.type === 'price' && (
                      <span class="font-[Roboto] text-[16px] sm:text-[22px] md:text-[32px] font-medium text-[#3e3e3e]">
                        {row.competitorA.amount.toLocaleString('ja-JP')}<span class="text-[10px] sm:text-[12px] md:text-[14px] font-semibold">円[税込]〜</span>
                      </span>
                    )}
                    {row.competitorA.type === 'price-zero' && (
                      <span class="font-[Roboto] text-[16px] sm:text-[22px] md:text-[32px] font-medium text-[#3e3e3e]">
                        0<span class="text-[10px] sm:text-[12px] md:text-[14px] font-semibold">円</span>
                      </span>
                    )}
                    {row.competitorA.type === 'circle' && (
                      <span class="font-[Roboto] text-[18px] sm:text-[24px] md:text-[32px] font-medium text-[#3e3e3e]" aria-label="対応">〇</span>
                    )}
                    {row.competitorA.type === 'cross' && (
                      <span class="font-[Roboto] text-[24px] sm:text-[32px] md:text-[48px] font-light text-[#3e3e3e]" aria-label="非対応">×</span>
                    )}
                    {row.competitorA.type === 'triangle' && (
                      <span class="font-[Roboto] text-[24px] sm:text-[32px] md:text-[40px] font-medium text-[#3e3e3e]" aria-label="要確認">△</span>
                    )}
                    {row.competitorA.type === 'text' && (
                      <span class="text-[11px] sm:text-[14px] md:text-[18px] font-bold text-[#3e3e3e]">{row.competitorA.value}</span>
                    )}
                  </td>
                  <td class={`p-2 sm:p-3 md:p-4${isLast ? ' rounded-br-lg' : ''}`}>
                    {row.competitorB.type === 'price' && (
                      <span class="font-[Roboto] text-[16px] sm:text-[22px] md:text-[32px] font-medium text-[#3e3e3e]">
                        {row.competitorB.amount.toLocaleString('ja-JP')}<span class="text-[10px] sm:text-[12px] md:text-[14px] font-semibold">円[税込]〜</span>
                      </span>
                    )}
                    {row.competitorB.type === 'price-zero' && (
                      <span class="font-[Roboto] text-[16px] sm:text-[22px] md:text-[32px] font-medium text-[#3e3e3e]">
                        0<span class="text-[10px] sm:text-[12px] md:text-[14px] font-semibold">円</span>
                      </span>
                    )}
                    {row.competitorB.type === 'circle' && (
                      <span class="font-[Roboto] text-[18px] sm:text-[24px] md:text-[32px] font-medium text-[#3e3e3e]" aria-label="対応">〇</span>
                    )}
                    {row.competitorB.type === 'cross' && (
                      <span class="font-[Roboto] text-[24px] sm:text-[32px] md:text-[48px] font-light text-[#3e3e3e]" aria-label="非対応">×</span>
                    )}
                    {row.competitorB.type === 'triangle' && (
                      <span class="font-[Roboto] text-[24px] sm:text-[32px] md:text-[40px] font-medium text-[#3e3e3e]" aria-label="要確認">△</span>
                    )}
                    {row.competitorB.type === 'text' && (
                      <span class="text-[11px] sm:text-[14px] md:text-[18px] font-bold text-[#3e3e3e]">{row.competitorB.value}</span>
                    )}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
