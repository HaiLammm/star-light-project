---
import { BLOG_CATEGORIES } from '../data/blogData';

interface Props {
  activeCategory?: string;
  activeSubcategory?: string;
}

const { activeCategory, activeSubcategory } = Astro.props;

function getCategoryUrl(catKey: string): string {
  return `/columns/category/${catKey}/`;
}

function getSubcategoryUrl(catKey: string, sub: string): string {
  return `/columns/category/${catKey}/${sub}/`;
}
---

<aside class="w-full lg:w-[285px] shrink-0">
  {BLOG_CATEGORIES.map((cat, i) => (
    <div class:list={[i > 0 && 'mt-[40px] sm:mt-[50px]']}>
      <a
        href={getCategoryUrl(cat.key)}
        class:list={[
          'flex items-center gap-[7px] text-[14px] sm:text-[15px] md:text-[16px] font-bold pb-[10px] border-b border-[#ccc]',
          activeCategory === cat.key && !activeSubcategory ? 'text-[#0044f2]' : 'text-[#1c1c1c]',
        ]}
      >
        <span class="block w-[8px] h-[8px] rounded-full bg-[#fbc101]"></span>
        {cat.label}
        <span class="ml-auto block w-[9px] h-[9px] border-t-[2px] border-r-[2px] border-[#0044f2] rotate-45"></span>
      </a>
      <ul>
        {cat.subcategories.map((sub) => (
          <li>
            <a
              href={getSubcategoryUrl(cat.key, sub)}
              class:list={[
                'flex items-center text-[12px] sm:text-[13px] md:text-[14px] py-[12px] sm:py-[14px] px-[10px] sm:px-[14px] border-b border-dotted border-[#979af3] transition-[padding-right] duration-200 hover:pr-[20px]',
                activeCategory === cat.key && activeSubcategory === sub ? 'text-[#0044f2] font-bold' : 'text-[#333]',
              ]}
            >
              {sub}
              <span class="ml-auto block w-[9px] h-[9px] border-t-[2px] border-r-[2px] border-[#0044f2] rotate-45"></span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  ))}
</aside>
