---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;

const items = [
  {
    sub: '見積りも相談料も',
    main: '安心の<b class="text-cta">0円</b>',
    accent: 'text-cta',
    // coin / yen
    icon: 'M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zm-3 7h6m-6 3h6m-3-5v8',
  },
  {
    sub: '最短かけつけ',
    main: '<b class="text-water">10分</b>',
    accent: 'text-water',
    // clock
    icon: 'M12 7v5l3 2M12 3a9 9 0 1 0 0 18 9 9 0 0 0 0-18z',
  },
  {
    sub: '必ず事前に',
    main: 'お見積り',
    accent: 'text-electric-deep',
    // document
    icon: 'M8 3h6l4 4v14H6V5a2 2 0 0 1 2-2zm6 0v4h4M9 13h6M9 17h6',
  },
  {
    sub: '年中無休',
    main: '<b class="text-navy">24時間365日</b>',
    accent: 'text-navy',
    // refresh / 24h
    icon: 'M3 12a9 9 0 0 1 15-6.7L21 8M21 4v4h-4M21 12a9 9 0 0 1-15 6.7L3 16m0 4v-4h4',
  },
];
---

<ul class={`grid grid-cols-2 md:grid-cols-4 gap-2.5 md:gap-3 max-w-[760px] mx-auto ${className}`}>
  {items.map((item) => (
    <li class="flex items-center gap-2.5 bg-water-tint border border-border-warm rounded-2xl px-3.5 py-2.5 md:px-4 md:py-3">
      <svg class={`w-6 h-6 md:w-7 md:h-7 shrink-0 ${item.accent}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d={item.icon} />
      </svg>
      <span class="leading-tight">
        <span class="block text-[10px] md:text-[11px] text-text-secondary font-medium">{item.sub}</span>
        <span class="block text-[14px] md:text-[16px] font-black text-navy" set:html={item.main} />
      </span>
    </li>
  ))}
</ul>
