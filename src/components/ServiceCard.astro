---
import type { ServiceItem } from '../utils/siteConfig';
import { formatPriceRange } from '../utils/formatters';

interface Props {
  service: ServiceItem;
  imageSrc: string;
  imageAlt: string;
  loading?: 'lazy' | 'eager';
}

const { service, imageSrc, imageAlt, loading = 'lazy' } = Astro.props;
---

<a href={service.href} class="group flex flex-col h-full">
  <figure class="w-full aspect-square rounded-[30px] md:rounded-[60px] overflow-hidden drop-shadow-[0_8px_0_#b2b2b2] flex-shrink-0">
    <img
      src={imageSrc}
      alt={imageAlt}
      width="640"
      height="640"
      decoding="auto"
      loading={loading}
      class="w-full h-full object-cover"
    />
  </figure>
  <div class="px-2 md:px-4 mt-4 md:mt-6 flex flex-col flex-grow overflow-hidden">
    <h3 class="text-base md:text-lg font-extrabold text-gray-900 leading-snug group-hover:text-cta transition-colors duration-200 ease line-clamp-2">{service.label}</h3>
    <p class="text-xs text-gray-600 mt-1 line-clamp-2">{service.description}</p>
    <div class="mt-auto pt-3">
      <div class="flex items-center gap-2 flex-wrap">
        <span class="text-xs">作業料金</span>
        <span class="inline-block bg-black text-white text-[10px] md:text-xs font-medium px-3 py-0.5 rounded-md">WEB割引</span>
      </div>
      <p class="font-[Roboto] text-2xl md:text-3xl font-bold text-cta flex items-center gap-1 mt-1 flex-wrap">
        {service.startingPrice.toLocaleString()}<span class="font-[Noto_Sans_JP] text-sm font-medium text-gray-900">円[税込]〜</span>
      </p>
    </div>
  </div>
</a>
