---
import { Image, getImage } from 'astro:assets';
import creditImg from '../assets/images/icons/credit.png';
import { SITE_CONFIG } from '../utils/siteConfig';
import { resolveImage } from '../utils/imageImports';

interface Step {
  number: number;
  image: string;
  title: string;
  heading: string;
  description: string;
}

interface Props {
  serviceName?: string;
  steps?: Step[];
  showPayment?: boolean;
}

const { serviceName, steps: customSteps, showPayment = true } = Astro.props;

const DEFAULT_STEPS: Step[] = [
  {
    number: 1,
    image: '/images/process/flow_01.png',
    title: 'ご相談',
    heading: '間違いでも構いません。<br>少しでも不調を感じたらいつでもお気軽にご相談下さい',
    description: '少しでも異変や不調を感じたらお気軽にご相談ください。<br>早朝深夜も営業しておりますので、急なトラブルでも安心してご連絡ください。',
  },
  {
    number: 2,
    image: '/images/process/flow_02.png',
    title: 'ご訪問',
    heading: 'お問い合わせから最短10分で最寄りの事業所から<br class="hidden md:inline">専門スタッフが現場に駆けつけます',
    description: '最寄りの事業所から最短10分で作業スタッフが急行いたします。<br>お客様の中には作業スタッフに一定数「怖い」イメージを持っている方もおられますが、当スタッフはマナー研修を実施。<br><br>安心・安全・丁寧を徹底しておりますので安心してご依頼ください。',
    },
  {
    number: 3,
    image: '/images/process/flow_03.png',
    title: 'お見積り',
    heading: 'トラブル内容を確認させていただき、事前にお見積りを提示。<br>ご納得いただけなければキャンセルいただいて構いません',
    description: 'トラブル内容を確認させていただき、事前にお見積りを提示。<br>ご納得いただけなければキャンセルいただいて構いません。<br>現場の状況を確認させていただき、しっかりと作業前に事前に見積りを提示させていただきます。<br>お見積りは無料、それ以外の出張費、早朝・深夜料金、キャンセル料もいただきません。',
  },
  {
    number: 4,
    image: '/images/process/flow_04.png',
    title: '作業',
    heading: '資格を有した専門スタッフが安心・安全を第一に<br class="hidden md:inline">迅速に作業を行います',
    description: 'お見積り内容に同意いただいた上で作業開始となります。<br>安心・安全を第一に迅速に作業いたします。<br>早いものであれば最短15分程度で作業完了いたします。',
  },
  {
    number: 5,
    image: '/images/process/flow_05.png',
    title: 'お支払',
    heading: '作業完了後、料金をお支払いいただき完了となります。<br>現金払い以外にも決済方法をご用意しております。',
    description: 'お支払いいただき作業完了となります。クレジットやキャッシュレスにも対応しておりますので、急なトラブルなどで現金のお手持ちがない場合でも問題ございません。',
  },
];

const rawSteps = (customSteps ?? DEFAULT_STEPS).filter(
  (s) => showPayment || s.number !== 5
);

const stepImageOptMap: Record<string, string> = {};
for (const step of rawSteps) {
  const meta = await resolveImage(step.image);
  if (meta) {
    const opt = await getImage({ src: meta, width: 400, height: 240, format: 'webp', quality: 80 });
    stepImageOptMap[step.image] = opt.src;
  }
}
const steps = rawSteps.map((s) => ({ ...s, image: stepImageOptMap[s.image] ?? s.image }));
---

<section class="pt-12 pb-8 md:pt-16 md:pb-6 lg:pt-[100px] lg:pb-[20px]">
  <div class="max-w-[1200px] mx-auto px-3 sm:px-4">
    <h2 class="text-[24px] md:text-[42px] font-bold relative isolate flex flex-col items-center text-center">
      <span class="block w-[2px] h-[40px] md:h-[70px] bg-[#fbc102]"></span>
      <span class="absolute top-[40px] md:top-[45px] left-1/2 -translate-x-1/2 opacity-30 font-[Roboto] text-[70px] md:text-[180px] font-bold text-[#b3b3b3] whitespace-nowrap -z-[1] pointer-events-none">Flow</span>
      {serviceName ? `${serviceName}修理までの流れ` : 'ご相談から修理までの流れ'}
    </h2>
    <div class="bg-[#f7f7f7] rounded-[16px] sm:rounded-[20px] md:rounded-[40px] px-3 sm:px-6 md:px-[45px] py-6 sm:py-10 md:py-16 mt-6 sm:mt-8 md:mt-12">
      <ol class="flex flex-col gap-8 sm:gap-10 md:gap-12 list-none p-0">
        {steps.map((step, index) => (
          <li class="flex flex-col md:flex-row items-start gap-3 sm:gap-4 md:gap-8 relative">
            {index > 0 && (
              <div class="absolute left-1/2 -translate-x-1/2 md:left-[200px] md:translate-x-0 top-0 -translate-y-full w-[2px] h-[30px] md:h-[100px] bg-[#ccc]"></div>
            )}
            <figure class="flex-shrink-0 w-full md:w-[400px] relative rounded-[12px] sm:rounded-[15px] md:rounded-[20px] overflow-hidden">
              <img
                src={step.image}
                alt={`ステップ${step.number}: ${step.title}`}
                width="400"
                height="240"
                decoding="auto"
                class="w-full h-auto object-cover aspect-[315/160] md:aspect-[400/240]"
              />
              <p class="absolute top-0 left-0 bg-white rounded-br-[24px] sm:rounded-br-[24px] md:rounded-br-[40px] w-[120px] h-[36px] sm:w-[140px] sm:h-[42px] md:w-[160px] md:h-[50px] pr-[14px] sm:pr-[16px] md:pr-[20px] text-[#0044f2] font-extrabold text-[18px] sm:text-[20px] md:text-[22px] flex items-center justify-center leading-[1.64]">
                <span class="font-[Roboto_Condensed] text-[32px] sm:text-[36px] md:text-[40px] font-semibold -tracking-wider mr-0.5 sm:mr-1 whitespace-nowrap">{step.number}.</span><span class="whitespace-nowrap">{step.title}</span>
              </p>
            </figure>
            <div class="flex-grow min-w-0 w-full overflow-hidden text-left">
              <p class="text-[16px] sm:text-[18px] md:text-[20px] font-bold leading-[1.56] mb-2 sm:mb-3 break-words overflow-wrap-anywhere" set:html={step.heading} />
              <p class="text-[13px] sm:text-[14px] md:text-base text-[#333] leading-[1.67] break-words overflow-wrap-anywhere" set:html={step.description} />
              {step.number === 5 && (
                <div class="mt-3 sm:mt-4">
                  <p class="text-[13px] sm:text-[14px] md:text-[16px] font-bold flex items-center gap-1.5">
                    <span class="w-[10px] h-[10px] rounded-full bg-[#fbc102] inline-block flex-shrink-0"></span>
                    お支払い方法
                  </p>
                  <p class="text-[12px] sm:text-[13px] md:text-[15px] text-[#333] leading-[1.67] mt-[7px]">現金、銀行振込、または各種クレジットカードがご利用頂けます。</p>
                  <figure class="mt-[10px]">
                    <Image src={creditImg} alt="クレジットカード" width={280} height={40} format="webp" quality={80} loading="lazy" decoding="async" class="w-auto h-[25px] sm:h-[30px] md:h-[35px]" />
                  </figure>
                </div>
              )}
              {step.number === 1 && (
                <div class="flex flex-col items-center md:flex-row md:items-start flex-wrap gap-[20px] mt-[16px] md:mt-[20px]">
                  <a
                    href="/contact"
                    class="inline-flex items-center justify-center gap-[6px] bg-[#ff4176] text-white font-bold w-[240px] h-[50px] rounded-[25px] shadow-[0_5px_0_0_rgba(0,0,0,0.3)] hover:translate-y-[2px] hover:shadow-[0_3px_0_0_rgba(0,0,0,0.3)] transition-all text-[18px]"
                  >
                    <img src="/images/cta/cta_contact_icon.svg" alt="" class="w-[30px] h-auto" />
                    メールで無料相談
                  </a>
                  <a
                    href={SITE_CONFIG.phone.href}
                    aria-label={SITE_CONFIG.phone.ariaLabel}
                    class="inline-flex flex-col items-center justify-center border-[2px] border-[#ff4176] bg-white w-[240px] h-[50px] rounded-[25px] shadow-[0_5px_0_0_rgba(0,0,0,0.3)] hover:translate-y-[2px] hover:shadow-[0_3px_0_0_rgba(0,0,0,0.3)] transition-all"
                  >
                    <span class="text-[10px] font-bold text-[#ff4176] border border-[#ff4176] rounded-[8px] px-3 py-0 leading-[14px]">電話相談無料！年中無休で対応</span>
                    <span class="text-[20px] font-bold font-[Roboto] text-[#ff4176] flex items-center gap-[3px]">
                      <img src="/images/cta/cta_tel_icon.svg" alt="" class="w-[13px] h-auto" style="filter:brightness(0) saturate(100%) invert(33%) sepia(92%) saturate(3026%) hue-rotate(330deg) brightness(97%) contrast(105%);" />
                      {SITE_CONFIG.phone.display}
                    </span>
                  </a>
                </div>
              )}
            </div>
          </li>
        ))}
      </ol>
    </div>

  </div>
</section>
