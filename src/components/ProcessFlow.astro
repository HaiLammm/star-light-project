---
import { Image, getImage } from 'astro:assets';
import creditImg from '../assets/images/icons/credit.png';
import { SITE_CONFIG } from '../utils/siteConfig';
import { resolveImage } from '../utils/imageImports';

interface Step {
  number: number;
  image: string;
  title: string;
  heading: string;
  description: string;
}

interface Props {
  serviceName?: string;
  steps?: Step[];
  showPayment?: boolean;
}

const { serviceName, steps: customSteps, showPayment = true } = Astro.props;

const DEFAULT_STEPS: Step[] = [
  {
    number: 1,
    image: '/images/process/flow_01.jpg',
    title: 'ご相談',
    heading: '間違いでも構いません。少しでも不調を感じたらいつでもお気軽にご相談下さい',
    description: '少しでも異変や不調を感じたらお気軽にご相談ください。早朝深夜も営業しておりますので、急なトラブルでも安心してご連絡ください。',
  },
  {
    number: 2,
    image: '/images/process/flow_02.jpg',
    title: 'ご訪問',
    heading: 'お問い合わせから最短10分で最寄りの事業所から専門スタッフが現場に駆けつけます',
    description: '最寄りの事業所から最短10分で作業スタッフが急行いたします。マナー研修を実施。安心・安全・丁寧を徹底しておりますので安心してご依頼ください。',
  },
  {
    number: 3,
    image: '/images/process/flow_03.jpg',
    title: 'お見積り',
    heading: 'トラブル内容を確認させていただき、事前にお見積りを提示。ご納得いただけなければキャンセルいただいて構いません',
    description: '現場の状況を確認させていただき、しっかりと作業前に事前に見積りを提示させていただきます。お見積りは無料、出張費、早朝・深夜料金、キャンセル料もいただきません。',
  },
  {
    number: 4,
    image: '/images/process/flow_04.jpg',
    title: '作業',
    heading: '資格を有した専門スタッフが安心・安全を第一に迅速に作業を行います',
    description: 'お見積り内容に同意いただいた上で作業開始となります。安心・安全を第一に迅速に作業いたします。早いものであれば最短15分程度で作業完了いたします。',
  },
  {
    number: 5,
    image: '/images/process/flow_05.jpg',
    title: 'お支払',
    heading: '作業完了後、料金をお支払いいただき完了となります',
    description: '現金、各種クレジットカード、銀行振込など豊富な決済方法をご用意しております。お支払い方法は作業前にご案内いたしますので、ご安心ください。',
  },
];

const rawSteps = (customSteps ?? DEFAULT_STEPS).filter(
  (s) => showPayment || s.number !== 5
);

const stepImageOptMap: Record<string, string> = {};
for (const step of rawSteps) {
  const meta = await resolveImage(step.image);
  if (meta) {
    const opt = await getImage({ src: meta, width: 400, height: 240, format: 'webp', quality: 80 });
    stepImageOptMap[step.image] = opt.src;
  }
}
const steps = rawSteps.map((s) => ({ ...s, image: stepImageOptMap[s.image] ?? s.image }));
---

<section class="pt-12 pb-8 md:pt-16 md:pb-6 lg:pt-[100px] lg:pb-[20px]">
  <div class="max-w-[1200px] mx-auto px-3 sm:px-4">
    <h2 class="text-[18px] sm:text-[24px] md:text-[42px] font-bold relative flex flex-col items-center text-center">
      <span class="block w-[2px] h-[25px] sm:h-[40px] md:h-[70px] bg-[#fbc102]"></span>
      <span class="absolute top-[25px] sm:top-[40px] md:top-[45px] left-1/2 -translate-x-1/2 opacity-30 font-[Roboto] text-[40px] sm:text-[70px] md:text-[180px] font-bold text-[#b3b3b3] whitespace-nowrap -z-[1] pointer-events-none">Flow</span>
      {serviceName ? `${serviceName}修理までの流れ` : 'ご相談から修理までの流れ'}
    </h2>
    <div class="bg-[#f7f7f7] rounded-[16px] sm:rounded-[20px] md:rounded-[40px] px-3 sm:px-6 md:px-[45px] py-6 sm:py-10 md:py-16 mt-6 sm:mt-8 md:mt-12">
      <ol class="flex flex-col gap-8 sm:gap-10 md:gap-12 list-none p-0">
        {steps.map((step, index) => (
          <li class="flex flex-col md:flex-row items-start gap-3 sm:gap-4 md:gap-8 relative">
            {index > 0 && (
              <div class="hidden md:block absolute left-[200px] -top-10 md:-top-12 w-0.5 h-10 md:h-12 bg-[#979bf3]"></div>
            )}
            <figure class="flex-shrink-0 w-full md:w-[400px] relative rounded-[12px] sm:rounded-[15px] md:rounded-[20px] overflow-hidden">
              <img
                src={step.image}
                alt={`ステップ${step.number}: ${step.title}`}
                width="400"
                height="240"
                decoding="auto"
                class="w-full h-auto object-cover aspect-[400/240]"
              />
              <p class="absolute top-0 left-0 bg-white rounded-br-[12px] sm:rounded-br-[15px] md:rounded-br-[20px] px-2 sm:px-4 md:px-6 py-1 sm:py-2 text-[#0044f2] font-bold text-[11px] sm:text-sm md:text-xl flex items-center">
                <span class="font-[Roboto_Condensed] text-[18px] sm:text-3xl md:text-4xl font-semibold -tracking-wider mr-0.5 sm:mr-1 whitespace-nowrap">{step.number}.</span><span class="whitespace-nowrap">{step.title}</span>
              </p>
            </figure>
            <div class="flex-grow min-w-0 w-full overflow-hidden">
              <p class="text-[12px] sm:text-base md:text-xl font-bold leading-snug mb-2 sm:mb-3 break-words overflow-wrap-anywhere">{step.heading}</p>
              <p class="text-[10px] sm:text-sm md:text-base text-gray-600 leading-snug break-words overflow-wrap-anywhere">{step.description}</p>
              {step.number === 1 && (
                <div class="flex flex-col sm:flex-row gap-2 sm:gap-3 mt-2 sm:mt-4 w-full">
                  <a
                    href="/contact"
                    class="inline-flex items-center justify-center bg-[#E8B341] text-white font-bold py-2 sm:py-3 px-4 sm:px-6 rounded-lg hover:shadow-lg transition-shadow text-[11px] sm:text-sm"
                  >
                    メールで無料相談
                  </a>
                  <a
                    href={SITE_CONFIG.phone.href}
                    aria-label={SITE_CONFIG.phone.ariaLabel}
                    class="inline-flex flex-col items-center justify-center border-2 border-[#E8B341] text-[#E8B341] font-bold py-1 sm:py-2 px-4 sm:px-6 rounded-lg hover:shadow-lg transition-shadow"
                  >
                    <span class="text-[9px] sm:text-xs">電話相談無料！年中無休で対応</span>
                    <span class="text-base sm:text-lg font-bold">{SITE_CONFIG.phone.display}</span>
                  </a>
                </div>
              )}
            </div>
          </li>
        ))}
      </ol>
    </div>

    {Boolean(showPayment) && <div class="mt-8 sm:mt-10 md:mt-[60px]">
      <h3 class="text-[14px] sm:text-[16px] md:text-[20px] font-bold text-center mb-5 sm:mb-6 md:mb-8">豊富な決済方法を<wbr />ご用意しております</h3>
      <div class="flex flex-col sm:flex-row justify-center items-stretch gap-4 sm:gap-6 md:gap-8">
        <div class="flex flex-col items-center gap-2 sm:gap-3">
          <p class="text-[13px] sm:text-[14px] md:text-[16px] font-bold">現金払い</p>
          <figure class="w-[60px] sm:w-[70px] md:w-[80px]">
            <img src="/images/icons/cash_icon.svg" alt="現金払い" width="80" height="80" loading="lazy" decoding="async" class="w-full h-auto" />
          </figure>
        </div>
        <div class="hidden sm:block w-px bg-gray-200 self-stretch"></div>
        <div class="flex flex-col items-center gap-2 sm:gap-3">
          <p class="text-[13px] sm:text-[14px] md:text-[16px] font-bold">クレジット/デビット決済</p>
          <figure class="w-[100px] sm:w-[120px] md:w-[140px]">
            <Image src={creditImg} alt="クレジット・デビット決済" width={140} height={60} format="webp" quality={80} loading="lazy" decoding="async" class="w-full h-auto" />
          </figure>
        </div>
        <div class="hidden sm:block w-px bg-gray-200 self-stretch"></div>
        <div class="flex flex-col items-center gap-2 sm:gap-3">
          <p class="text-[13px] sm:text-[14px] md:text-[16px] font-bold">銀行振込</p>
          <p class="text-[12px] sm:text-[13px] md:text-[15px] text-center text-gray-600">お近くの<span class="font-bold text-[14px] sm:text-[16px] md:text-[18px]">銀行</span>または<span class="font-bold text-[14px] sm:text-[16px] md:text-[18px]">郵便局</span></p>
        </div>
      </div>
    </div>}
  </div>
</section>
