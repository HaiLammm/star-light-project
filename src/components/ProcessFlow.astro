---
import { SITE_CONFIG } from '../utils/siteConfig';

interface Step {
  number: number;
  image: string;
  title: string;
  heading: string;
  description: string;
}

const steps: Step[] = [
  {
    number: 1,
    image: '/images/process/flow_01.jpg',
    title: 'ご相談',
    heading: '間違いでも構いません。少しでも不調を感じたらいつでもお気軽にご相談下さい',
    description: '少しでも異変や不調を感じたらお気軽にご相談ください。早朝深夜も営業しておりますので、急なトラブルでも安心してご連絡ください。',
  },
  {
    number: 2,
    image: '/images/process/flow_02.jpg',
    title: 'ご訪問',
    heading: 'お問い合わせから最短10分で最寄りの事業所から専門スタッフが現場に駆けつけます',
    description: '最寄りの事業所から最短10分で作業スタッフが急行いたします。マナー研修を実施。安心・安全・丁寧を徹底しておりますので安心してご依頼ください。',
  },
  {
    number: 3,
    image: '/images/process/flow_03.jpg',
    title: 'お見積り',
    heading: 'トラブル内容を確認させていただき、事前にお見積りを提示。ご納得いただけなければキャンセルいただいて構いません',
    description: '現場の状況を確認させていただき、しっかりと作業前に事前に見積りを提示させていただきます。お見積りは無料、出張費、早朝・深夜料金、キャンセル料もいただきません。',
  },
  {
    number: 4,
    image: '/images/process/flow_04.jpg',
    title: '作業',
    heading: '資格を有した専門スタッフが安心・安全を第一に迅速に作業を行います',
    description: 'お見積り内容に同意いただいた上で作業開始となります。安心・安全を第一に迅速に作業いたします。早いものであれば最短15分程度で作業完了いたします。',
  },
  {
    number: 5,
    image: '/images/process/flow_05.jpg',
    title: 'お支払',
    heading: '作業完了後、料金をお支払いいただき完了となります。現金払い以外にも決済方法をご用意しております。',
    description: 'お支払いいただき作業完了となります。クレジットやキャッシュレスにも対応しておりますので、急なトラブルなどで現金のお手持ちがない場合でも問題ございません。',
  },
];
---

<section class="py-16 md:py-20">
  <div class="max-w-[1200px] mx-auto px-4">
    <div class="bg-[#f7f7f7] rounded-[2rem] md:rounded-[4rem] px-4 md:px-12 py-10 md:py-16">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-8 md:mb-12">
        ご相談から修理までの流れ<span class="text-sm md:text-base font-normal text-[#E8B341] tracking-widest ml-2">Flow</span>
      </h2>
      <ol class="flex flex-col gap-10 md:gap-12 list-none p-0">
        {steps.map((step, index) => (
          <li class="flex flex-col md:flex-row items-start gap-4 md:gap-8 relative">
            {index > 0 && (
              <div class="hidden md:block absolute left-[10rem] -top-10 md:-top-12 w-0.5 h-10 md:h-12 bg-[#979bf3]"></div>
            )}
            <figure class="flex-shrink-0 w-full md:w-[400px] relative rounded-[1.5rem] md:rounded-[2rem] overflow-hidden">
              <img
                src={step.image}
                alt={`ステップ${step.number}: ${step.title}`}
                width="400"
                height="240"
                decoding="auto"
                class="w-full h-auto object-cover aspect-[400/240]"
              />
              <p class="absolute top-0 left-0 bg-white rounded-br-[1.5rem] md:rounded-br-[2rem] px-4 md:px-6 py-2 text-[#0044f2] font-bold text-lg md:text-xl flex items-center">
                <span class="font-[Roboto_Condensed] text-3xl md:text-4xl font-semibold -tracking-wider mr-1">{step.number}.</span>{step.title}
              </p>
            </figure>
            <div class="flex-grow">
              <p class="text-lg md:text-xl font-bold leading-relaxed mb-3">{step.heading}</p>
              <p class="text-sm text-gray-600 leading-relaxed">{step.description}</p>
              {step.number === 1 && (
                <div class="flex flex-col sm:flex-row gap-3 mt-4">
                  <a
                    href="/contact"
                    class="inline-flex items-center justify-center bg-[#E8B341] text-white font-bold py-3 px-6 rounded-lg hover:shadow-lg transition-shadow text-sm"
                  >
                    メールで無料相談
                  </a>
                  <a
                    href={SITE_CONFIG.phone.href}
                    aria-label={SITE_CONFIG.phone.ariaLabel}
                    class="inline-flex flex-col items-center justify-center border-2 border-[#E8B341] text-[#E8B341] font-bold py-2 px-6 rounded-lg hover:shadow-lg transition-shadow"
                  >
                    <span class="text-xs">電話相談無料！年中無休で対応</span>
                    <span class="text-lg font-bold">{SITE_CONFIG.phone.display}</span>
                  </a>
                </div>
              )}
              {step.number === 5 && (
                <div class="mt-3">
                  <p class="text-sm font-bold text-gray-700 mb-1">お支払い方法</p>
                  <p class="text-xs text-gray-600">現金、銀行振込、または各種クレジットカードがご利用頂けます。</p>
                </div>
              )}
            </div>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>
