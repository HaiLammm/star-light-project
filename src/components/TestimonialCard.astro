---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { formatPrice } from '../utils/formatters';

interface Props {
  serviceType: string;
  serviceCategory: 'electricity' | 'water';
  title?: string;
  duration?: string;
  cost: number;
  message: string;
  authorInitial: string;
  location?: string;
  imageSrc: ImageMetadata | string;
  imageAlt: string;
}

const {
  serviceType,
  serviceCategory,
  title,
  duration,
  cost,
  message,
  authorInitial,
  location,
  imageSrc,
  imageAlt,
} = Astro.props;

const categoryColorMap: Record<string, string> = {
  electricity: 'bg-[#fb7502]',
  water: 'bg-[#2f76eb]',
};

const categoryColor = categoryColorMap[serviceCategory] ?? 'bg-[#717070]';
const cardTitle = title ?? `${serviceType}をご依頼いただいたお客様の声`;
---

<article class="h-full">
  <a href="/voice" class="flex flex-col w-full h-full p-[15px] sm:p-[20px] md:p-[30px] md:pb-[35px] rounded-[20px] sm:rounded-[30px] md:rounded-[50px] shadow-[0_8px_0_0_rgba(0,0,0,0.16)] bg-[#f7f7f7] hover:shadow-[0_8px_0_0_rgba(0,0,0,0.24)] transition-shadow duration-200 ease">
    <div class="flex items-start gap-[12px] sm:gap-[15px] md:gap-[20px]">
      <figure class="shrink-0 w-[60px] sm:w-[70px] md:w-[100px] aspect-square rounded-[12px] sm:rounded-[14px] md:rounded-[20px] overflow-hidden">
        {typeof imageSrc === 'string' ? (
          <img src={imageSrc} alt={imageAlt} width="300" height="300" decoding="async" loading="lazy" class="w-full h-full object-cover" />
        ) : (
          <Image src={imageSrc} alt={imageAlt} width={300} height={300} format="webp" quality={80} loading="lazy" decoding="async" class="w-full h-full object-cover" />
        )}
      </figure>
      <div class="grow min-w-0">
        <ul class="flex gap-[6px] md:gap-[9px] flex-wrap">
          <li class={`${categoryColor} text-white text-[9px] sm:text-[10px] md:text-[11px] font-bold leading-[1.27] px-[3px] py-[2px] pb-[1px] rounded-[4px] sm:rounded-[5px]`}>
            {serviceType}
          </li>
          {location && (
            <li class="bg-[#717070] text-white text-[9px] sm:text-[10px] md:text-[11px] font-bold leading-[1.27] px-[3px] py-[2px] pb-[1px] rounded-[4px] sm:rounded-[5px]">
              {location}
            </li>
          )}
        </ul>
        <h3 class="text-[12px] sm:text-[14px] md:text-[18px] font-bold leading-[1.5] mt-[6px] sm:mt-[8px] md:mt-[10px] line-clamp-2">
          {cardTitle}
        </h3>
      </div>
    </div>
    <blockquote class="text-[10px] sm:text-[11px] md:text-[12px] text-[#333] leading-[1.5] mt-[10px] sm:mt-[14px] md:mt-[20px] mb-[8px] sm:mb-[10px] md:mb-[15px] line-clamp-2">
      <p>{message}</p>
      <cite class="not-italic text-[9px] sm:text-[10px] md:text-[11px] text-[#666] block mt-[4px]">{authorInitial}</cite>
    </blockquote>
    <div class="w-full px-[6px] sm:px-[8px] md:px-[10px] py-[5px] sm:py-[6px] md:py-[8px] pb-[3px] sm:pb-[4px] md:pb-[6px] rounded-[12px] sm:rounded-[14px] md:rounded-[20px] bg-white flex justify-center gap-[10px] sm:gap-[14px] md:gap-[20px] mt-auto">
      {duration && (
        <div class="flex flex-col items-center pr-[10px] sm:pr-[14px] md:pr-[20px] border-r border-dotted border-[#707070]">
          <p class="text-[9px] sm:text-[10px] md:text-[12px] leading-[1.17]">作業時間</p>
          <p class="font-[Roboto] text-[18px] sm:text-[22px] md:text-[32px] font-bold">
            {duration}<span class="text-[9px] sm:text-[11px] md:text-[14px] font-medium">分</span>
          </p>
        </div>
      )}
      <div class="flex flex-col items-center">
        <p class="text-[9px] sm:text-[10px] md:text-[12px] leading-[1.17]">作業料金</p>
        <p class="font-[Roboto] text-[18px] sm:text-[22px] md:text-[32px] font-bold">
          {formatPrice(cost)}<span class="text-[9px] sm:text-[11px] md:text-[14px] font-medium">円</span>
        </p>
      </div>
    </div>
  </a>
</article>
