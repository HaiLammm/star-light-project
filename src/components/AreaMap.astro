---
import { Image } from 'astro:assets';
import areaMapImg from '../assets/images/area_2026.png';
---

<section class="py-12 md:py-16 lg:pt-[100px] lg:pb-[80px]">
  <div class="max-w-[1200px] mx-auto px-3 sm:px-4">
    <h2 class="text-[24px] md:text-[42px] font-bold relative flex flex-col items-center text-center">
      <span class="block w-[2px] h-[40px] md:h-[70px] bg-[#fbc102]"></span>
      <span class="absolute top-[40px] md:top-[45px] left-1/2 -translate-x-1/2 opacity-30 font-[Roboto] text-[70px] md:text-[180px] font-bold text-[#b3b3b3] whitespace-nowrap -z-[1] pointer-events-none">Area</span>
      対応エリア
    </h2>
    <p class="text-center text-[11px] sm:text-[12px] md:text-[14px] text-[#555] mt-4 sm:mt-6 mb-6 sm:mb-8 md:mb-10">
      年中無休で稼働しております。
    </p>

    <div class="flex justify-center">
      <Image
        src={areaMapImg}
        alt="設備プロのサービス対応エリアマップ"
        width={600}
        height={450}
        format="webp"
        quality={80}
        decoding="async"
        loading="lazy"
        class="w-full max-w-[600px] h-auto"
      />
    </div>
  </div>
</section>
