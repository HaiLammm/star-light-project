---
interface AreaRegion {
  name: string;
  prefs: string[];
}

const areaRegions: AreaRegion[] = [
  { name: '関東エリア', prefs: ['東京都', '神奈川県', '埼玉県', '千葉県', '茨城県', '栃木県'] },
  { name: '東海エリア', prefs: ['三重県', '岐阜県', '愛知県', '静岡県'] },
  { name: '関西エリア', prefs: ['大阪府', '京都府', '兵庫県'] },
  { name: '中国エリア', prefs: ['広島県'] },
];
---

<section id="area" class="py-8 md:py-16 lg:pt-[100px] lg:pb-[80px]">
  <div class="max-w-[1120px] mx-auto px-3 sm:px-4">
    <div class="text-center">
      <span class="inline-flex items-center gap-2.5 text-[13px] font-bold tracking-[0.08em] text-navy">
        <span class="w-7 h-[3px] rounded-sm bg-navy"></span>対応エリア
      </span>
      <h2 class="text-[23px] md:text-[30px] font-black text-navy mt-3">対応エリア</h2>
    </div>
    <p class="text-center text-balance text-[12px] md:text-[14px] text-text-secondary mt-3 mb-8 md:mb-10">
      年中無休で稼働しております。東京・名古屋・大阪・広島を中心に対応。
    </p>

    <div class="grid md:grid-cols-[minmax(0,1fr)_360px] gap-8 md:gap-10 items-center rounded-[20px] md:rounded-[40px] bg-white border border-border-warm shadow-[0_6px_24px_rgba(27,42,74,0.06)] px-5 py-8 md:px-10 md:py-12">
      <!-- Map -->
      <figure class="w-full max-w-[560px] mx-auto">
        <img
          src="/images/map/japan-areas.svg"
          alt="設備プロのサービス対応エリアマップ（関東・東海・関西・中国地方）"
          width="600"
          height="600"
          loading="lazy"
          decoding="async"
          class="w-full h-auto"
        />
        <figcaption class="flex items-center justify-center gap-4 mt-3 text-[12px] text-text-secondary">
          <span class="inline-flex items-center gap-1.5"><span class="w-3 h-3 rounded-[3px] bg-water"></span>対応エリア</span>
          <span class="inline-flex items-center gap-1.5"><span class="w-3 h-3 rounded-[3px] bg-[#D7E3EC]"></span>その他</span>
        </figcaption>
      </figure>

      <!-- Legend -->
      <ul class="flex flex-col gap-4">
        {areaRegions.map((region) => (
          <li class="bg-cream border border-border-warm rounded-2xl p-4">
            <p class="flex items-center gap-1.5 font-black text-navy text-[15px] md:text-[16px]">
              <svg class="w-4 h-4 shrink-0 text-water" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2c-3.87 0-7 3.13-7 7 0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5A2.5 2.5 0 1 1 12 6.5a2.5 2.5 0 0 1 0 5z" />
              </svg>
              {region.name}
            </p>
            <ul class="flex flex-wrap gap-1.5 mt-2.5">
              {region.prefs.map((pref) => (
                <li class="bg-water-tint text-water-deep text-[12px] font-bold leading-none px-2.5 py-1.5 rounded-full">{pref}</li>
              ))}
            </ul>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
