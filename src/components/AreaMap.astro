---
import { Image } from 'astro:assets';
import areaMapImg from '../assets/images/area_2026.png';

interface Props {
  serviceSlug?: string;
  category?: string;
}

const { serviceSlug = '', category = 'electricity' } = Astro.props;

const regions = [
  {
    name: '関西エリア',
    prefectures: ['大阪府', '京都府', '兵庫県'],
  },
  {
    name: '東海エリア',
    prefectures: ['三重県', '岐阜県', '静岡県', '愛知県'],
  },
  {
    name: '中国エリア',
    prefectures: ['広島県'],
  },
  {
    name: '関東エリア',
    prefectures: ['東京都', '埼玉県', '神奈川県'],
  },
];
---

<section class="py-12 md:py-16 lg:pt-[100px] lg:pb-[80px]">
  <div class="max-w-[1200px] mx-auto px-3 sm:px-4">
    <h2 class="text-[18px] sm:text-[24px] md:text-[42px] font-bold relative flex flex-col items-center text-center">
      <span class="block w-[2px] h-[25px] sm:h-[40px] md:h-[70px] bg-[#fbc102]"></span>
      <span class="absolute top-[25px] sm:top-[40px] md:top-[45px] left-1/2 -translate-x-1/2 opacity-30 font-[Roboto] text-[40px] sm:text-[70px] md:text-[180px] font-bold text-[#b3b3b3] whitespace-nowrap -z-[1] pointer-events-none">Area</span>
      対応エリア
    </h2>
    <p class="text-center text-[11px] sm:text-[12px] md:text-[14px] text-[#555] mt-4 sm:mt-6 mb-6 sm:mb-8 md:mb-10">
      年中無休で稼働しております。
    </p>

    <div class="flex flex-col lg:flex-row gap-6 lg:gap-10 items-start">
      <div class="w-full lg:w-[55%]">
        <Image
          src={areaMapImg}
          alt="設備人のサービス対応エリアマップ"
          width={600}
          height={450}
          format="webp"
          quality={80}
          decoding="async"
          loading="lazy"
          class="w-full h-auto"
        />
      </div>
      <div class="w-full lg:w-[45%]">
        <div class="flex flex-col gap-5 sm:gap-6">
          {regions.map((region) => (
            <div>
              <p class="text-[13px] sm:text-[14px] md:text-[16px] font-bold text-[#1c1c1c] mb-2 sm:mb-3">{region.name}</p>
              <div class="flex flex-wrap gap-2">
                {region.prefectures.map((pref) => (
                  <a
                    href={`/${category}/${serviceSlug}/${pref.replace('都', '').replace('道', '').replace('府', '').replace('県', '').toLowerCase()}/`}
                    class="text-[11px] sm:text-[12px] md:text-[13px] text-[#0044f2] hover:underline"
                  >
                    {pref}
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
