---
import { SITE_CONFIG, NAVIGATION, REGIONAL_OFFICES } from '../utils/siteConfig';
---

<footer class="bg-navy text-white">
  <div class="max-w-[1200px] mx-auto px-4 md:px-6 lg:px-10">
    <div class="py-10 text-center border-b border-white/20">
      <p class="text-sm mb-2">お困りごとはお気軽にご相談ください</p>
      <a
        href={SITE_CONFIG.phone.href}
        aria-label={SITE_CONFIG.phone.ariaLabel}
        class="text-3xl md:text-4xl font-bold text-orange hover:opacity-80 transition-opacity"
      >
        {SITE_CONFIG.phone.display}
      </a>
      <p class="text-sm mt-2 text-white/70">{SITE_CONFIG.businessHours}受付</p>
    </div>

    <nav aria-label="フッターナビゲーション" class="py-10 border-b border-white/20">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {NAVIGATION.map((item) => (
          <div>
            <a href={item.href} class="font-bold text-sm hover:text-orange transition-colors">
              {item.label}
            </a>
            {item.children && (
              <ul class="mt-3 space-y-2">
                {item.children.map((child) => (
                  <li>
                    <a href={child.href} class="text-sm text-white/70 hover:text-orange transition-colors">
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))}
      </div>
    </nav>

    <div class="py-8 border-b border-white/20">
      <p class="font-bold text-sm mb-4">{SITE_CONFIG.legalName}</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {REGIONAL_OFFICES.map((office) => (
          <div class="text-sm text-white/70">
            <p class="font-medium text-white">{office.shortName}</p>
            <p>{office.formattedAddress}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="py-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-white/70">
      <p>&copy; {new Date().getFullYear()} {SITE_CONFIG.legalName}</p>
      <a href="/privacy" class="hover:text-orange transition-colors">プライバシーポリシー</a>
    </div>
  </div>
</footer>
