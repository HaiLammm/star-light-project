---
import { SITE_CONFIG, NAVIGATION } from '../utils/siteConfig';

const FOOTER_NAV = [
  {
    label: '電気まわりサービス',
    href: '/electricity',
    children: [
      { label: 'ブレーカーサービス', href: '/electricity/breaker' },
      { label: 'コンセントサービス', href: '/electricity/outlet' },
      { label: '照明サービス', href: '/electricity/illumination' },
      { label: 'アンテナ工事サービス', href: '/electricity/antenna' },
      { label: '給湯器交換サービス', href: '/electricity/waterheater' },
      { label: 'エアコンサービス', href: '/electricity/air-conditioner' },
    ],
  },
  {
    label: '水まわりサービス',
    href: '/sanitary',
    children: [
      { label: 'トイレサービス', href: '/sanitary/toilet' },
      { label: 'キッチンサービス', href: '/sanitary/kitchen' },
      { label: 'お風呂サービス', href: '/sanitary/bath' },
      { label: '洗面所サービス', href: '/sanitary/washroom' },
    ],
  },
  {
    label: '会社案内',
    href: '/company',
    children: [
      { label: '会社概要', href: '/company/about' },
      { label: '企業理念', href: '/company/philosophy' },
      { label: '採用ページ', href: '/company/recruit' },
      { label: '対応エリア', href: '/company/office' },
    ],
  },
  {
    label: 'はじめてご利用の方へ',
    children: [
      { label: '作業の流れ', href: '/flow' },
      { label: '施工事例', href: '/case' },
      { label: 'お客さまの声', href: '/voice' },
      { label: 'コラム', href: '/columns' },
      { label: 'よくある質問', href: '/faq' },
    ],
  },
  {
    label: 'サイト情報',
    children: [
      { label: '無料相談フォーム', href: '/contact' },
      { label: 'カスタマーフォーム', href: '/customer' },
      { label: 'プライバシーポリシー', href: '/privacy' },
      { label: 'サイトマップ', href: '/sitemap' },
    ],
  },
];
---

<footer class="mb-[80px] md:mb-0">
  <div class="max-w-[1200px] mx-auto pt-[30px] pb-[16px] md:pt-[50px] md:pb-[45px] px-[12px] md:px-[45px]">
    <figure class="w-[153px] md:w-[230px] mx-auto">
      <img src="/images/site_logo_no-mark.jpeg" alt={SITE_CONFIG.siteName} width="230" height="60" loading="lazy" decoding="async" class="w-full h-auto" />
    </figure>

    <nav aria-label="フッターナビゲーション" class="mt-[10px] md:mt-[50px] px-[12px] md:px-[45px]">
      <div class="flex flex-col md:flex-row md:gap-[9px]">
        {FOOTER_NAV.map((section) => (
          <div class="flex-1 py-[20px] md:py-0 border-b border-[#ccc] md:border-b-0 last:border-b-0">
            {section.href ? (
              <a href={section.href} class="text-[14px] md:text-[16px] font-bold flex items-center gap-[7px] hover:text-[#fbc101] transition-colors">
                <span class="w-[8px] h-[8px] rounded-full bg-[#fbc101] shrink-0"></span>
                {section.label}
              </a>
            ) : (
              <p class="text-[14px] md:text-[16px] font-bold flex items-center gap-[7px]">
                <span class="w-[8px] h-[8px] rounded-full bg-[#fbc101] shrink-0"></span>
                {section.label}
              </p>
            )}
            {section.children && (
              <ul class="mt-[10px] md:mt-[20px] grid grid-cols-2 md:flex md:flex-col gap-[10px] md:gap-[15px]">
                {section.children.map((child) => (
                  <li>
                    <a href={child.href} class="text-[12px] md:text-[14px] text-[#333] flex items-center gap-[7px] md:gap-[7px] hover:text-[#fbc101] transition-colors">
                      <span class="w-[6px] h-[2px] bg-[#fbc101] shrink-0"></span>
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))}
      </div>
    </nav>
  </div>
  <p class="bg-[#0044f2] text-white text-center text-[12px] py-[11px] md:py-[12px]">Copyright &copy; SETSUBI-PRO.</p>
</footer>
