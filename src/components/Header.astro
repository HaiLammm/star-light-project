---
import { SITE_CONFIG, NAVIGATION } from '../utils/siteConfig';
import MegaMenu from './MegaMenu.astro';
import MobileMenu from './MobileMenu.tsx';
---

<header data-header class="fixed top-0 left-0 right-0 z-50 bg-white transition-shadow">
  <div class="w-full flex items-center justify-between h-[60px] sm:h-[80px] lg:h-[100px] px-2 sm:px-3">
    <h1 class="shrink-0 relative z-10 m-0 leading-none">
      <a href="/">
        <img src="/images/site_logo.svg" alt={SITE_CONFIG.companyName} class="w-[100px] sm:w-[140px] lg:w-[230px] object-contain" />
      </a>
    </h1>

    <nav aria-label="メインナビゲーション" class="hidden lg:flex items-center justify-end h-full">
      <div class="flex items-center gap-5 xl:gap-8">
        <MegaMenu />
      </div>

      <div class="ml-5 xl:ml-7 flex flex-col items-center">
        <span class="inline-flex items-center justify-center px-4 h-5 rounded-full border border-[#2856cb] text-[11px] font-bold text-[#2856cb] max-w-[180px] text-center">
          電話相談無料！年中無休で対応
        </span>
        <a
          href={SITE_CONFIG.phone.href}
          aria-label={SITE_CONFIG.phone.ariaLabel}
          class="font-['Roboto',sans-serif] text-[26px] font-bold text-[#0044f2] hover:opacity-70 transition-opacity max-w-[200px] text-center break-words"
        >
          {SITE_CONFIG.phone.display}
        </a>
      </div>

      <a
        href="/contact"
        class="ml-3 self-start w-[160px] h-[80px] flex items-center justify-center rounded-bl-[20px] bg-[#fc4076] hover:bg-[#d32a5a] text-white text-lg font-bold leading-tight text-center transition-colors"
      >
        <span>メールで<br />無料相談</span>
      </a>
    </nav>

    <div class="flex items-center gap-2 sm:gap-4 lg:hidden">
      <a
        href={SITE_CONFIG.phone.href}
        aria-label={SITE_CONFIG.phone.ariaLabel}
        class="text-orange font-bold text-[12px] sm:text-sm min-w-[40px] min-h-[40px] flex items-center justify-center"
      >
        {SITE_CONFIG.phone.display}
      </a>

      <button
        type="button"
        id="mobile-menu-trigger"
        aria-label="メニューを開く"
        aria-controls="mobile-menu"
        aria-expanded="false"
        class="min-w-[44px] min-h-[44px] flex items-center justify-center"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
</header>

<div class="h-[60px] sm:h-[80px] lg:h-[100px]"></div>

<MobileMenu client:load navigation={NAVIGATION} phone={SITE_CONFIG.phone} />

<script>
  const header = document.querySelector('[data-header]');
  if (header) {
    window.addEventListener('scroll', () => {
      header.classList.toggle('shadow-md', window.scrollY > 0);
    }, { passive: true });
  }
</script>
