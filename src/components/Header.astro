---
import { SITE_CONFIG, NAVIGATION } from '../utils/siteConfig';
import MegaMenu from './MegaMenu.astro';
import MobileMenu from './MobileMenu.tsx';
---

<header data-header class="fixed top-0 left-0 right-0 z-50 bg-white transition-shadow">
  <div class="w-full flex items-center justify-between h-[60px] lg:h-[100px] pl-[10px] pr-[60px] lg:pl-[20px] lg:pr-0">
    <h1 class="shrink-0 relative z-10 m-0 leading-none">
      <a href="/">
        <img src="/images/site_logo_no-mark.jpeg" alt={SITE_CONFIG.companyName} class="w-[153px] lg:w-[230px] object-contain" />
      </a>
    </h1>

    <nav aria-label="メインナビゲーション" class="hidden lg:flex items-center justify-end h-full">
      <div class="flex items-center gap-5 xl:gap-8">
        <MegaMenu />
      </div>

      <div class="ml-5 xl:ml-7 flex flex-col items-center">
        <span class="inline-flex items-center justify-center w-[186px] h-[20px] rounded-[10px] border border-[#2856cb] text-[11px] font-bold text-[#2856cb] whitespace-nowrap leading-none">
          電話相談無料！年中無休で対応
        </span>
        <a
          href={SITE_CONFIG.phone.href}
          aria-label={SITE_CONFIG.phone.ariaLabel}
          class="flex items-center justify-center gap-[3px] font-['Roboto',sans-serif] text-[26px] font-bold text-[#0044f2] hover:opacity-70 transition-opacity mb-[15px]"
        >
          <img src="/images/cta/cta_tel_icon.svg" alt="" class="w-[14px] h-auto" style="filter:brightness(0) saturate(100%) invert(18%) sepia(89%) saturate(3642%) hue-rotate(224deg) brightness(95%) contrast(107%);" />
          {SITE_CONFIG.phone.display}
        </a>
      </div>

      <a
        href="/contact"
        class="ml-[9px] self-start w-[160px] h-[80px] xl:h-[100px] flex items-center justify-center gap-[7px] rounded-bl-[20px] bg-[#fc4076] hover:opacity-90 text-white text-[18px] font-bold leading-[1.2] text-center transition-opacity"
      >
        <img src="/images/cta/cta_contact_icon.svg" alt="" class="w-[40px] h-[40px]" />
        <span>メールで<br />無料相談</span>
      </a>
    </nav>

    <!-- Mobile: contact button -->
    <a
      href="/contact"
      class="lg:hidden absolute top-0 right-[60px] w-[60px] h-[60px] flex flex-col items-center justify-center gap-[3px] bg-[#fc4076]"
    >
      <img src="/images/cta/cta_contact_icon.svg" alt="" class="w-[24px] h-[24px]" />
      <span class="text-[10px] font-bold text-white leading-tight text-center">無料相談</span>
    </a>
  </div>
</header>

<!-- Mobile hamburger: fixed, z-[999] so it stays above the menu overlay -->
<button
  type="button"
  id="mobile-menu-trigger"
  aria-label="メニューを開く"
  aria-controls="mobile-menu"
  aria-expanded="false"
  class="hamburger lg:hidden fixed top-0 right-0 z-[999] w-[60px] h-[60px] cursor-pointer transition-all duration-300"
>
  <span class="hamburger__line"></span>
</button>

<div class="h-[60px] lg:h-[100px]"></div>

<MobileMenu client:load navigation={NAVIGATION} phone={SITE_CONFIG.phone} />

<style>
  .hamburger__line {
    position: absolute;
    top: 0; right: 0; bottom: 0; left: 0;
    margin: auto;
    width: 24px;
    height: 2px;
    background-color: #0044f2;
    transition: transform 0.3s, background-color 0.3s;
  }
  .hamburger__line::before,
  .hamburger__line::after {
    content: "";
    display: block;
    width: 100%;
    height: 2px;
    background-color: inherit;
    position: absolute;
    transition: transform 0.3s, top 0.3s, background-color 0.3s;
  }
  .hamburger__line::before { top: 7px; }
  .hamburger__line::after { top: -7px; }

  .hamburger[aria-expanded="true"] .hamburger__line {
    background-color: transparent;
  }
  .hamburger[aria-expanded="true"] .hamburger__line::before {
    top: 0;
    background-color: #fff;
    transform: rotate(45deg);
  }
  .hamburger[aria-expanded="true"] .hamburger__line::after {
    top: 0;
    background-color: #fff;
    transform: rotate(-45deg);
  }
</style>

<script>
  const header = document.querySelector('[data-header]');
  if (header) {
    window.addEventListener('scroll', () => {
      header.classList.toggle('shadow-md', window.scrollY > 0);
    }, { passive: true });
  }
</script>
