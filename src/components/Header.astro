---
import { SITE_CONFIG, NAVIGATION } from '../utils/siteConfig';
import MegaMenu from './MegaMenu.astro';
import MobileMenu from './MobileMenu.tsx';
---

<header data-header class="fixed top-0 left-0 right-0 z-50 bg-white transition-shadow">
  <!-- Mobile header -->
  <div class="lg:hidden w-full flex items-center justify-between h-[60px] pl-[10px] pr-[120px]">
    <h1 class="shrink-0 m-0 leading-none">
      <a href="/">
        <img src="/images/site_logo_no-mark.jpeg" alt={SITE_CONFIG.companyName} class="w-[153px] object-contain" />
      </a>
    </h1>
    <a
      href="/contact"
      class="absolute top-0 right-[60px] w-[60px] h-[60px] flex flex-col items-center justify-center gap-[3px] bg-[#fc4076]"
    >
      <img src="/images/cta/cta_contact_icon.svg" alt="" class="w-[24px] h-[24px]" />
      <span class="text-[10px] font-bold text-white leading-tight text-center">無料相談</span>
    </a>
  </div>

  <!-- Desktop header: uses vw-based unit for proportional scaling -->
  <div
    class="hidden lg:flex w-full items-center justify-between"
    style="--h:clamp(8px,0.8065vw,10px);height:calc(var(--h)*10);padding-left:calc(var(--h)*2);"
  >
    <h1 class="shrink-0 relative z-10 m-0 leading-none">
      <a href="/">
        <img src="/images/site_logo_no-mark.jpeg" alt={SITE_CONFIG.companyName} style="width:calc(var(--h)*23);" class="object-contain" />
      </a>
    </h1>

    <nav aria-label="メインナビゲーション" class="flex items-center justify-end h-full">
      <div class="flex items-center" style="gap:calc(var(--h)*2);">
        <MegaMenu />
      </div>

      <div class="flex flex-col items-center shrink-0" style="margin-left:calc(var(--h)*1.8);">
        <span
          class="inline-flex items-center justify-center rounded-[10px] border border-[#2856cb] font-bold text-[#2856cb] whitespace-nowrap leading-none"
          style="width:calc(var(--h)*18.6);height:calc(var(--h)*2);font-size:calc(var(--h)*1.1);"
        >
          電話相談無料！年中無休で対応
        </span>
        <a
          href={SITE_CONFIG.phone.href}
          aria-label={SITE_CONFIG.phone.ariaLabel}
          class="flex items-center justify-center font-['Roboto',sans-serif] font-bold text-[#0044f2] hover:opacity-70 transition-opacity whitespace-nowrap"
          style="font-size:calc(var(--h)*2.6);gap:calc(var(--h)*0.3);margin-bottom:calc(var(--h)*1.5);"
        >
          <img src="/images/cta/cta_tel_icon.svg" alt="" style="width:calc(var(--h)*1.38);height:auto;filter:brightness(0) saturate(100%) invert(18%) sepia(89%) saturate(3642%) hue-rotate(224deg) brightness(95%) contrast(107%);" />
          {SITE_CONFIG.phone.display}
        </a>
      </div>

      <a
        href="/contact"
        class="self-start flex items-center justify-center rounded-bl-[20px] bg-[#fc4076] hover:opacity-90 text-white font-bold leading-[1.2] text-center transition-opacity shrink-0"
        style="width:calc(var(--h)*16);height:calc(var(--h)*10);font-size:calc(var(--h)*1.8);gap:calc(var(--h)*0.7);margin-left:calc(var(--h)*0.9);"
      >
        <img src="/images/cta/cta_contact_icon.svg" alt="" style="width:calc(var(--h)*4);height:auto;" />
        <span>メールで<br />無料相談</span>
      </a>
    </nav>
  </div>
</header>

<!-- Mobile hamburger: fixed, z-[999] so it stays above the menu overlay -->
<button
  type="button"
  id="mobile-menu-trigger"
  aria-label="メニューを開く"
  aria-controls="mobile-menu"
  aria-expanded="false"
  class="hamburger lg:hidden fixed top-0 right-0 z-[999] w-[60px] h-[60px] cursor-pointer transition-all duration-300"
>
  <span class="hamburger__line"></span>
</button>

<div class="h-[60px] lg:hidden"></div>
<div class="hidden lg:block" style="height:calc(clamp(8px,0.8065vw,10px)*10);"></div>

<MobileMenu client:load navigation={NAVIGATION} phone={SITE_CONFIG.phone} />

<style>
  .hamburger__line {
    position: absolute;
    top: 0; right: 0; bottom: 0; left: 0;
    margin: auto;
    width: 24px;
    height: 2px;
    background-color: #0044f2;
    transition: transform 0.3s, background-color 0.3s;
  }
  .hamburger__line::before,
  .hamburger__line::after {
    content: "";
    display: block;
    width: 100%;
    height: 2px;
    background-color: inherit;
    position: absolute;
    transition: transform 0.3s, top 0.3s, background-color 0.3s;
  }
  .hamburger__line::before { top: 7px; }
  .hamburger__line::after { top: -7px; }

  .hamburger[aria-expanded="true"] .hamburger__line {
    background-color: transparent;
  }
  .hamburger[aria-expanded="true"] .hamburger__line::before {
    top: 0;
    background-color: #fff;
    transform: rotate(45deg);
  }
  .hamburger[aria-expanded="true"] .hamburger__line::after {
    top: 0;
    background-color: #fff;
    transform: rotate(-45deg);
  }
</style>

<script>
  const header = document.querySelector('[data-header]');
  if (header) {
    window.addEventListener('scroll', () => {
      header.classList.toggle('shadow-md', window.scrollY > 0);
    }, { passive: true });
  }
</script>
