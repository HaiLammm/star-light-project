---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { formatPriceNumber } from '../utils/formatters';

interface Props {
  title: string;
  serviceCategory: 'electricity' | 'water';
  categoryLabel: string;
  location: string;
  duration: string;
  cost: number;
  description: string;
  imageSrc: ImageMetadata | string;
  imageAlt: string;
  serviceSlug: string;
}

const {
  title,
  serviceCategory,
  categoryLabel,
  location,
  duration,
  cost,
  description,
  imageSrc,
  imageAlt,
  serviceSlug,
} = Astro.props;

const categoryColorMap: Record<string, string> = {
  electricity: 'bg-electric-deep',
  water: 'bg-water',
};

const categoryColor = categoryColorMap[serviceCategory] ?? 'bg-[#717070]';
---

<article class="h-full">
  <a href={`/${serviceCategory}/${serviceSlug}/`} class="flex flex-col w-full h-full p-[20px] md:p-[30px] md:pb-[35px] rounded-[40px] md:rounded-[50px] border border-border-warm shadow-[0_6px_24px_rgba(27,42,74,0.08)] bg-white hover:-translate-y-1 transition-transform duration-200 ease">
    <div class="flex items-start gap-[10px] md:gap-[20px]">
      <figure class="shrink-0 w-[80px] md:w-[100px] aspect-square rounded-[20px] overflow-hidden">
        {typeof imageSrc === 'string' ? (
          <img src={imageSrc} alt={imageAlt} width="300" height="300" decoding="async" loading="lazy" class="w-full h-full object-cover" />
        ) : (
          <Image src={imageSrc} alt={imageAlt} width={300} height={300} format="webp" quality={80} loading="lazy" decoding="async" class="w-full h-full object-cover" />
        )}
      </figure>
      <div class="grow min-w-0">
        <ul class="flex gap-[8px] md:gap-[9px] flex-wrap">
          <li class={`${categoryColor} text-white text-[10px] md:text-[11px] font-bold leading-[1.27] px-[4px] py-[3px] pb-[2px] rounded-[5px]`}>
            {categoryLabel}
          </li>
          <li class="bg-[#717070] text-white text-[10px] md:text-[11px] font-bold leading-[1.27] px-[4px] py-[3px] pb-[2px] rounded-[5px]">
            {location}
          </li>
        </ul>
        <h3 class="text-[16px] md:text-[18px] font-bold leading-[1.5] md:leading-[1.67] mt-[10px] break-words overflow-wrap-anywhere">
          {title}
        </h3>
      </div>
    </div>
    <p class="text-[11px] md:text-[12px] text-[#333] leading-[1.5] mt-[9px] md:mt-[20px] mb-[10px] md:mb-[15px] break-words overflow-wrap-anywhere line-clamp-3 md:line-clamp-2">
      {description}
    </p>
    <div class="w-full px-[10px] py-[7px] md:py-[8px] pb-[7px] md:pb-[6px] rounded-[20px] bg-cream flex justify-center gap-[20px] mt-auto">
      <div class="flex flex-col items-center pr-[20px] border-r border-dotted border-border-warm">
        <p class="text-[11px] md:text-[12px] leading-[1.17] text-text-secondary">作業時間</p>
        <p class="font-[Roboto] text-[30px] md:text-[32px] font-bold text-navy">
          {duration}<span class="text-[13px] md:text-[14px] font-medium ml-[5px] md:ml-[2px]">分</span>
        </p>
      </div>
      <div class="flex flex-col items-center">
        <p class="text-[11px] md:text-[12px] leading-[1.17] text-text-secondary">作業料金</p>
        <p class="font-[Roboto] text-[30px] md:text-[32px] font-bold text-cta">
          {formatPriceNumber(cost)}<span class="text-[13px] md:text-[14px] font-medium ml-[5px] md:ml-[2px] text-navy">円</span>
        </p>
      </div>
    </div>
  </a>
</article>
