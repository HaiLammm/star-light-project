---
interface AnchorSection {
  id: string;
  label: string;
  icon: string;
}

interface Props {
  sections: AnchorSection[];
}

const { sections } = Astro.props;
---

<div class="sticky top-[80px] z-40 bg-white py-3 sm:py-4 shadow-sm">
  <div class="max-w-[1200px] mx-auto px-3 sm:px-4">
    <nav aria-label="ページ内ナビゲーション">
      <ul class="anchor-list flex justify-center border border-[#b5b5b5] bg-white rounded-[32px] px-4 sm:px-6 md:px-11 py-2 md:py-[9px]">
        {sections.map((section) => (
          <li class="anchor-item flex-1 flex items-center">
            <a
              href={`#${section.id}`}
              class="w-full h-[44px] md:h-[45px] flex items-center gap-1.5 text-[12px] sm:text-[13px] md:text-[14px] font-medium text-[#1c1c1c] rounded-lg transition-colors duration-200 hover:bg-[#f7f7f7] pr-2 md:pr-4"
              aria-label={`${section.label}セクションへジャンプ`}
            >
              <img
                src={section.icon}
                alt=""
                aria-hidden="true"
                width="28"
                height="28"
                class="w-5 h-5 sm:w-6 sm:h-6 md:w-7 md:h-7 object-contain flex-shrink-0"
                loading="eager"
                decoding="async"
              />
              <span class="whitespace-nowrap">{section.label}</span>
              <span class="ml-auto w-[7px] h-[7px] border-r-2 border-b-2 border-[#0044f2] rotate-45 flex-shrink-0" aria-hidden="true"></span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</div>

<style>
  @media (max-width: 900px) {
    .anchor-list {
      display: grid !important;
      grid-template-columns: repeat(2, 1fr);
      gap: 11px;
      border-radius: 24px;
      padding: 15px 16px;
    }
    .anchor-item {
      flex: unset;
      position: relative;
    }
    .anchor-item:nth-child(even)::after {
      content: "";
      display: block;
      background-color: #b5b5b5;
      width: 1px;
      height: 20px;
      position: absolute;
      top: 50%;
      left: -6px;
      transform: translateY(-50%);
    }
  }
</style>
