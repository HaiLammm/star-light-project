---
interface AnchorSection {
  id: string;
  label: string;
  icon: string;
}

interface Props {
  sections: AnchorSection[];
}

const { sections } = Astro.props;
---

<div class="sticky top-[60px] sm:top-[80px] lg:top-[100px] z-40 bg-white py-2 sm:py-3 md:py-4 shadow-sm">
  <div class="max-w-[1200px] mx-auto px-3 sm:px-4">
    <nav aria-label="ページ内ナビゲーション" class="anchor-scroll-wrapper">
      <ul class="anchor-inner flex md:justify-center border border-[#b5b5b5] bg-white rounded-[20px] md:rounded-[32px] px-3 sm:px-6 md:px-11 py-2 md:py-[9px] gap-1 md:gap-0 w-max md:w-full">
        {sections.map((section) => (
          <li class="shrink-0 md:flex-1 flex items-center">
            <a
              href={`#${section.id}`}
              class="flex items-center gap-1 md:gap-1.5 text-[11px] sm:text-[12px] md:text-[14px] font-medium text-[#1c1c1c] rounded-lg transition-colors duration-200 hover:bg-[#f7f7f7] h-[40px] md:h-[45px] px-1.5 md:px-2 md:pr-4 whitespace-nowrap"
              aria-label={`${section.label}セクションへジャンプ`}
            >
              <img
                src={section.icon}
                alt=""
                aria-hidden="true"
                width="28"
                height="28"
                class="w-5 h-5 md:w-7 md:h-7 object-contain shrink-0"
                loading="eager"
                decoding="async"
              />
              <span>{section.label}</span>
              <span class="ml-1 md:ml-auto w-[6px] h-[6px] md:w-[7px] md:h-[7px] border-r-2 border-b-2 border-[#0044f2] rotate-45 shrink-0" aria-hidden="true"></span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</div>

<style>
  .anchor-scroll-wrapper {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .anchor-scroll-wrapper::-webkit-scrollbar {
    display: none;
  }
  @media (min-width: 768px) {
    .anchor-scroll-wrapper {
      overflow-x: visible;
    }
  }
</style>
