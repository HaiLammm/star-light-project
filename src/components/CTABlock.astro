---
import { Image, getImage } from 'astro:assets';
import { SITE_CONFIG } from '../utils/siteConfig';
import ctaDecoImg from '../assets/images/cta/cta_deco.png';
import ctaSanitaryImg from '../assets/images/cta/cta_sanitary_button_2026.png';
import ctaSanitarySpImg from '../assets/images/cta/cta_sanitary_button_sp_2026.png';

const sanitaryDesktop = await getImage({ src: ctaSanitaryImg, format: 'webp', quality: 80 });
const sanitaryMobile = await getImage({ src: ctaSanitarySpImg, format: 'webp', quality: 80 });

interface Props {
  variant: 'full-width' | 'compact' | 'sticky';
}

const { variant } = Astro.props;
const phone = SITE_CONFIG.phone;
---

{variant === 'sticky' && (
  <div
    class="fixed bottom-0 left-0 right-0 z-40 md:hidden pb-[env(safe-area-inset-bottom)]"
    style="--u:min(2.6667vw,11px);backdrop-filter:blur(calc(var(--u)*3));background:rgba(255,255,255,0.6);"
  >
    <div class="flex items-center justify-center" style="padding:var(--u);gap:calc(var(--u)*0.5);">
      <a
        href={phone.href}
        aria-label={phone.ariaLabel}
        class="flex flex-col items-center justify-center bg-white"
        style="width:calc(var(--u)*29);height:calc(var(--u)*6);border:calc(var(--u)*0.2) solid #1B2A4A;border-radius:calc(var(--u)*1.6);"
      >
        <span
          class="flex items-center justify-center font-bold text-water"
          style="width:calc(var(--u)*18);height:calc(var(--u)*1.65);border-radius:calc(var(--u)*0.8);border:calc(var(--u)*0.1) solid var(--color-water);font-size:var(--u);line-height:1;"
        >
          電話相談無料！年中無休で対応
        </span>
        <span
          class="flex items-center justify-center font-bold text-navy"
          style="font-family:'Roboto',sans-serif;font-size:calc(var(--u)*2.4);line-height:1;gap:calc(var(--u)*0.5);"
        >
          <img src="/images/cta/cta_tel_icon.svg" alt="" style="width:calc(var(--u)*1.33);height:auto;flex-shrink:0;filter:brightness(0) saturate(100%) invert(13%) sepia(28%) saturate(1648%) hue-rotate(189deg) brightness(95%) contrast(92%);" />
          {phone.display}
        </span>
      </a>
      <a
        href="/contact"
        class="flex flex-col items-center justify-center bg-cta"
        style="width:calc(var(--u)*6);height:calc(var(--u)*6);gap:calc(var(--u)*0.3);border-radius:calc(var(--u)*1.6);"
      >
        <img src="/images/cta/cta_contact_icon.svg" alt="" style="width:calc(var(--u)*2.4);height:auto;aspect-ratio:1/1;" />
        <span class="font-bold text-white text-center" style="font-size:var(--u);line-height:1.2;">無料相談</span>
      </a>
    </div>
  </div>
)}

{variant === 'full-width' && (
  <section style="background: #1B2A4A;">
    <div class="w-full max-w-[1240px] mx-auto px-[2.6667vw] md:px-8 py-[30px] md:py-[50px]">

      <!-- White card container (position: relative to anchor the absolute deco) -->
      <div class="relative bg-white rounded-[40px] px-5 pt-10 pb-9 md:rounded-[40px] md:px-10 md:pt-[46px] md:pb-[45px]">

        <!-- cta_deco: overflows top-right, absolute -->
        <div class="pointer-events-none absolute right-0 z-10 w-[123px] -top-[26px] md:w-[277px] md:-top-[50px] md:right-[23px]">
          <Image src={ctaDecoImg} alt="" format="webp" quality={80} loading="lazy" decoding="async" class="w-full h-auto object-contain" />
        </div>

        <!-- Lead text -->
        <p class="relative z-20 text-center font-extrabold text-[15px] md:text-[20px] pr-[100px] md:pr-0">
          少しでも不調を感じたら<br class="md:hidden" />いつでもお気軽にご相談ください
        </p>

        <!-- Heading: Logo + に修理相談 -->
        <p class="relative z-20 flex flex-wrap items-center justify-center gap-x-1 mt-5 md:mt-1 font-extrabold text-[29px] md:text-[40px]">
          <img src="/images/site_logo_no-mark.jpeg" alt="設備プロ" loading="lazy" decoding="async" class="w-[177px] md:w-[230px] h-auto object-contain mr-0.5" />
          <span class="text-[21px] md:text-[28px]">に</span>修理相談
        </p>

        <!-- cta_feature banner -->
        <figure class="relative z-20 mx-auto mt-8 md:mt-[18px] w-full max-w-[828px]">
          <picture>
            <source media="(max-width: 900px)" srcset="/images/cta/cta_feature_sp.svg" />
            <source media="(min-width: 901px)" srcset="/images/cta/cta_feature.svg" />
            <img src="/images/cta/cta_feature.svg" alt="" loading="lazy" decoding="async" class="w-full h-auto" />
          </picture>
        </figure>

        <!-- Buttons row -->
        <div class="relative z-20 flex flex-col md:flex-row justify-center gap-[10px] md:gap-[30px] mt-[22px] md:mt-[20px]">

          <!-- Phone button: white bg, pink border -->
          <div class="w-full md:w-[350px] h-[72px] md:h-[88px]">
            <a
              href={phone.href}
              aria-label={phone.ariaLabel}
              class="flex w-full h-full flex-col items-center justify-center rounded-[36px] md:rounded-[44px] border-2 border-navy bg-white transition-shadow duration-200 shadow-[0_6px_24px_rgba(27,42,74,0.12)] hover:shadow-[0_10px_28px_rgba(27,42,74,0.18)]"
            >
              <span class="flex h-[20px] w-[216px] items-center justify-center rounded-full border border-water text-[10px] md:h-[22px] md:w-[240px] md:text-[12px] font-bold text-water">
                電話相談無料！年中無休で対応
              </span>
              <span class="mt-0.5 flex items-center gap-[3px] font-['Roboto',sans-serif] text-[28px] md:text-[32px] font-bold text-navy">
                <img src="/images/cta/cta_tel_icon.svg" alt="" class="mb-0.5 h-auto w-[16px] md:w-[18px]" style="filter:brightness(0) saturate(100%) invert(13%) sepia(28%) saturate(1648%) hue-rotate(189deg) brightness(95%) contrast(92%);" />
                {phone.display}
              </span>
            </a>
          </div>

          <!-- Contact button: orange CTA -->
          <div class="w-full md:w-[350px] h-[72px] md:h-[88px]">
            <a
              href="/contact"
              class="flex w-full h-full items-center justify-center gap-[14px] md:gap-[15px] rounded-[36px] md:rounded-[44px] bg-cta hover:bg-cta-deep text-white text-[21px] md:text-[24px] font-bold transition-colors duration-200 shadow-[0_8px_20px_rgba(255,107,0,0.28)]"
            >
              <img src="/images/cta/cta_contact_icon.svg" alt="" class="h-auto w-[36px] md:w-[40px]" />
              メールで無料相談
            </a>
          </div>
        </div>
      </div>

      <!-- Service page-link buttons -->
      <div class="mx-auto mt-5 md:mt-[40px] flex w-full max-w-[980px] flex-col md:flex-row items-center justify-center gap-4 md:gap-0 md:h-[132px]">
        <div class="w-full flex-1">
          <a href="/electricity" class="block transition-opacity hover:opacity-90">
            <picture>
              <source media="(max-width: 900px)" srcset="/images/cta/cta_electricity_button_sp.svg" />
              <source media="(min-width: 901px)" srcset="/images/cta/cta_electricity_button.svg" />
              <img src="/images/cta/cta_electricity_button.svg" alt="電気まわりのトラブル" loading="lazy" decoding="async" class="w-full h-auto object-contain" />
            </picture>
          </a>
        </div>
        <div class="w-full flex-1">
          <a href="/sanitary" class="block transition-opacity hover:opacity-90">
            <picture>
              <source media="(max-width: 900px)" srcset={sanitaryMobile.src} />
              <source media="(min-width: 901px)" srcset={sanitaryDesktop.src} />
              <img src={sanitaryDesktop.src} alt="水まわりのトラブル" width={sanitaryDesktop.attributes.width} height={sanitaryDesktop.attributes.height} loading="lazy" decoding="async" class="w-full h-auto object-contain" />
            </picture>
          </a>
        </div>
      </div>

    </div>
  </section>
)}

{variant === 'compact' && (
  <div class="bg-bg-secondary py-6 md:py-8 px-4">
    <div class="max-w-3xl mx-auto flex flex-wrap items-center justify-center gap-3 sm:gap-4">
      <a
        href={phone.href}
        aria-label={phone.ariaLabel}
        class="inline-flex items-center gap-2 bg-orange text-white font-bold text-lg px-4 py-2 rounded-lg min-h-[44px] min-w-[44px] hover:opacity-90 transition-opacity"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" viewBox="0 0 20 20" fill="currentColor">
          <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
        </svg>
        {phone.display}
      </a>
      <span class="text-xs text-text-secondary">通話無料</span>
      <span class="bg-red text-white text-xs font-bold px-2 py-1 rounded -rotate-[5deg] shrink-0">
        WEB割引
      </span>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 bg-navy text-white font-bold px-4 py-2 rounded-lg min-h-[44px] min-w-[44px] hover:opacity-90 transition-opacity text-sm"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor">
          <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
          <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
        </svg>
        メールで無料相談
      </a>
    </div>
  </div>
)}
