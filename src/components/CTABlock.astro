---
import { SITE_CONFIG } from '../utils/siteConfig';

interface Props {
  variant: 'full-width' | 'compact' | 'sticky';
}

const { variant } = Astro.props;
const phone = SITE_CONFIG.phone;
---

{variant === 'sticky' && (
  <div class="fixed bottom-0 left-0 right-0 z-40 bg-white border-t border-border-light shadow-[0_-2px_8px_rgba(0,0,0,0.1)] md:hidden pb-[env(safe-area-inset-bottom)]">
    <div class="flex items-center justify-center gap-3 px-4 py-2">
      <a
        href={phone.href}
        aria-label={phone.ariaLabel}
        class="flex items-center gap-2 min-w-[44px] min-h-[44px]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-orange shrink-0" viewBox="0 0 20 20" fill="currentColor">
          <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
        </svg>
        <span class="text-xs text-text-secondary">通話無料</span>
        <span class="text-orange font-bold text-lg">{phone.display}</span>
      </a>
      <span class="bg-red text-white text-xs font-bold px-2 py-1 rounded -rotate-[5deg] shrink-0">
        WEB割引
      </span>
    </div>
  </div>
)}

{variant === 'full-width' && (
  <div class="bg-orange text-white py-4 px-4 text-center">
    <a
      href={phone.href}
      aria-label={phone.ariaLabel}
      class="inline-flex items-center gap-2 text-2xl font-bold min-h-[44px]"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor">
        <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
      </svg>
      {phone.display}
    </a>
    <p class="text-sm mt-1">通話無料 {SITE_CONFIG.businessHours}</p>
  </div>
)}

{variant === 'compact' && (
  <div class="inline-flex items-center gap-2">
    <a
      href={phone.href}
      aria-label={phone.ariaLabel}
      class="flex items-center gap-1 text-orange font-bold min-h-[44px] min-w-[44px]"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
      </svg>
      {phone.display}
    </a>
  </div>
)}
