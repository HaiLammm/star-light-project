---
import { SITE_CONFIG } from '../utils/siteConfig';

interface Props {
  variant: 'full-width' | 'compact' | 'sticky';
}

const { variant } = Astro.props;
const phone = SITE_CONFIG.phone;
---

{variant === 'sticky' && (
  <div class="fixed bottom-0 left-0 right-0 z-40 bg-white border-t border-border-light shadow-[0_-2px_8px_rgba(0,0,0,0.1)] md:hidden pb-[env(safe-area-inset-bottom)]">
    <div class="flex items-center justify-center gap-3 px-4 py-2">
      <a
        href={phone.href}
        aria-label={phone.ariaLabel}
        class="flex items-center gap-2 min-w-[44px] min-h-[44px]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-orange shrink-0" viewBox="0 0 20 20" fill="currentColor">
          <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
        </svg>
        <span class="text-xs text-text-secondary">通話無料</span>
        <span class="text-orange font-bold text-lg">{phone.display}</span>
      </a>
      <span class="bg-red text-white text-xs font-bold px-2 py-1 rounded -rotate-[5deg] shrink-0">
        WEB割引
      </span>
    </div>
  </div>
)}

{variant === 'full-width' && (
  <section class="bg-bg-secondary py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-xl md:text-2xl font-bold text-navy mb-2">電話相談無料！年中無休で対応</h2>
      <p class="text-text-secondary text-sm mb-6">{SITE_CONFIG.businessHours}いつでもお気軽にご相談ください</p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6">
        <div class="flex items-center gap-3">
          <a
            href={phone.href}
            aria-label={phone.ariaLabel}
            class="inline-flex items-center gap-2 bg-orange text-white text-2xl md:text-3xl font-bold px-6 py-3 rounded-lg min-h-[44px] min-w-[44px] hover:opacity-90 transition-opacity"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 shrink-0" viewBox="0 0 20 20" fill="currentColor">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
            </svg>
            {phone.display}
          </a>
          <span class="text-xs text-text-secondary">通話無料</span>
        </div>

        <span class="bg-red text-white text-xs font-bold px-2 py-1 rounded -rotate-[5deg] shrink-0">
          WEB割引 1,500円割引!
        </span>

        <a
          href="/contact"
          class="inline-flex items-center gap-2 bg-navy text-white font-bold px-6 py-3 rounded-lg min-h-[44px] min-w-[44px] hover:opacity-90 transition-opacity"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
            <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
          </svg>
          メールで無料相談
        </a>
      </div>
    </div>
  </section>
)}

{variant === 'compact' && (
  <div class="bg-bg-secondary py-6 md:py-8 px-4">
    <div class="max-w-3xl mx-auto flex flex-wrap items-center justify-center gap-3 sm:gap-4">
      <a
        href={phone.href}
        aria-label={phone.ariaLabel}
        class="inline-flex items-center gap-2 bg-orange text-white font-bold text-lg px-4 py-2 rounded-lg min-h-[44px] min-w-[44px] hover:opacity-90 transition-opacity"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" viewBox="0 0 20 20" fill="currentColor">
          <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
        </svg>
        {phone.display}
      </a>
      <span class="text-xs text-text-secondary">通話無料</span>
      <span class="bg-red text-white text-xs font-bold px-2 py-1 rounded -rotate-[5deg] shrink-0">
        WEB割引
      </span>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 bg-navy text-white font-bold px-4 py-2 rounded-lg min-h-[44px] min-w-[44px] hover:opacity-90 transition-opacity text-sm"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor">
          <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
          <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
        </svg>
        メールで無料相談
      </a>
    </div>
  </div>
)}
